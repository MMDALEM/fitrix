<!doctype html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%
        // مقادیر SEO با fallback امن — کنترلرها می‌توانند بازنویسی کنند
        var _siteName = settings.siteName || "فیت ریکس شاپ";
        var _siteNameEn = settings.siteNameEn || "FitRix";
        var _title = (typeof pageTitle !== "undefined" && pageTitle)
            ? pageTitle + " | " + _siteName + " (" + _siteNameEn + ")"
            : _siteName + " (" + _siteNameEn + ") | خرید مکمل ورزشی | fitrix.ir";
        var _desc = (typeof metaDescription !== "undefined" && metaDescription) ? metaDescription : "";
        var _canonical = (typeof canonicalUrl !== "undefined" && canonicalUrl) ? canonicalUrl : "";
        var _ogImage = (typeof ogImage !== "undefined" && ogImage) ? ogImage : "/images/logo.png";
        var _ogType = (typeof ogType !== "undefined" && ogType) ? ogType : "website";
        var _noindex = (typeof noindex !== "undefined" && noindex) ? true : false;
        var _siteUrl = (typeof siteUrl !== "undefined" && siteUrl) ? siteUrl : "";
        var _keywords = (typeof metaKeywords !== "undefined" && metaKeywords)
            ? (Array.isArray(metaKeywords) ? metaKeywords.filter(Boolean).join(", ") : metaKeywords)
            : "";
        // og:image باید همیشه آدرسِ مطلق باشد؛ اگر نسبی بود، دامنه را جلویش می‌گذاریم
        var _ogImageAbs = /^https?:\/\//i.test(_ogImage) ? _ogImage : (_siteUrl + _ogImage);
    %>
    <title><%= _title %></title>
    <meta name="description" content="<%= _desc %>" />
    <% if (_keywords) { %>
    <meta name="keywords" content="<%= _keywords %>" />
    <% } %>
    <% if (_noindex) { %>
    <meta name="robots" content="noindex, nofollow" />
    <% } else { %>
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <% } %>
    <% if (_canonical) { %>
    <link rel="canonical" href="<%= _canonical %>" />
    <% } %>
    <meta name="theme-color" content="#2563eb" />

    <!-- سرعتِ اتصال به سرویس‌های شخص ثالث (بهبودِ Core Web Vitals) -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="<%= _siteName %>" />
    <meta property="og:locale" content="fa_IR" />
    <meta property="og:type" content="<%= _ogType %>" />
    <meta property="og:title" content="<%= _title %>" />
    <meta property="og:description" content="<%= _desc %>" />
    <% if (_canonical) { %>
    <meta property="og:url" content="<%= _canonical %>" />
    <% } %>
    <meta property="og:image" content="<%= _ogImageAbs %>" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= _title %>" />
    <meta name="twitter:description" content="<%= _desc %>" />
    <meta name="twitter:image" content="<%= _ogImageAbs %>" />
    

    <!-- Structured Data: Organization + WebSite -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "<%= _siteName %>",
      "alternateName": ["<%= _siteNameEn %>", "Fitrix", "فیت ریکس"],
      "url": "<%= _siteUrl %>/",
      "logo": "<%= _siteUrl %>/images/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+98-937-364-0517",
        "contactType": "customer service"
      }
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "<%= _siteName %>",
      "alternateName": ["<%= _siteNameEn %>", "Fitrix", "فیت ریکس"],
      "url": "<%= _siteUrl %>/",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "<%= _siteUrl %>/shop?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-596GHZPT');</script>
    <!-- End Google Tag Manager -->

    <link rel="stylesheet" href="/styles/app.css">
    <link rel="stylesheet" href="/styles/swiper-bundle.css">
    <link rel="stylesheet" href="/styles/sweetalert2.min.css" >
    <link rel="stylesheet" href="/styles/program.css">
    <link rel="stylesheet" href="/styles/anatomy.css">
    <link rel="stylesheet" href="/styles/motion.css">
    <link rel="icon" type="image/png" href="/images/logo-1.png" />
    <!-- شبکه‌ی ایمنی تصاویر: عکس‌ها روی همه ابعاد (موبایل و دسکتاپ) یکدست بمانند و چیدمان را نریزند -->
    <style>
        img { max-width: 100%; }
        /* اسلایدر عکس اصلی صفحه محصول: کل عکس دیده شود */
        .ProductDetailsSlider img,
        .MobileProductSlider img { max-width: 100%; height: auto; }
        /* کارت محصول: کادر عکس همیشه یک‌اندازه و کل عکس (بدون بریدگی) نمایش داده شود
           — این باعث می‌شود عکس‌ها با ابعاد مختلف، در موبایل و کامپیوتر یکسان دیده شوند */
        .product-card > a { display: block; width: 100% !important; height: 12rem !important; position: relative; }
        .product-card_img { width: 100% !important; height: 12rem !important; object-fit: contain !important; }
        @media (max-width: 480px) {
            .product-card > a { height: 9.5rem !important; }
            .product-card_img { height: 9.5rem !important; }
        }

        /* ==========================================================
           لودینگ تصاویر: تا وقتی عکس نیامده، حالت مات + شیمر (در حال
           بارگذاری) نمایش داده می‌شود؛ به‌محض آماده‌شدن، نرم جایگزین
           می‌شود تا کاربر منتظرِ دیدنِ لودِ خالی نماند.
           (اسکریپت /scripts/img-blur.js کلاس‌ها را مدیریت می‌کند)
           ========================================================== */
        /* حالتِ در حال بارگذاری: یک شیمرِ مات و واضح (اسکلت لودینگ) */
        img.img-blur-load {
            background-color: #e6eaef;
            background-image: linear-gradient(100deg,
                rgba(255,255,255,0) 30%,
                rgba(255,255,255,.75) 50%,
                rgba(255,255,255,0) 70%);
            background-size: 200% 100%;
            background-repeat: no-repeat;
            background-position: 150% 0;
            animation: imgShimmer 1.2s ease-in-out infinite;
        }
        .dark img.img-blur-load {
            background-color: #273244;
            background-image: linear-gradient(100deg,
                rgba(255,255,255,0) 30%,
                rgba(255,255,255,.14) 50%,
                rgba(255,255,255,0) 70%);
        }
        /* پس از آماده‌شدن: شیمر حذف و عکس با بلورِ نرم ظاهر می‌شود (blur-in) */
        img.img-blur-load.is-loaded {
            background-image: none;
            background-color: transparent;
            animation: imgBlurIn .5s ease-out forwards;
        }
        @keyframes imgShimmer {
            0%   { background-position: 150% 0; }
            100% { background-position: -150% 0; }
        }
        @keyframes imgBlurIn {
            from { filter: blur(12px); opacity: .35; }
            to   { filter: blur(0);    opacity: 1; }
        }
        @media (prefers-reduced-motion: reduce) {
            img.img-blur-load { animation: none; }
            img.img-blur-load.is-loaded { animation: none; }
        }
    </style>
    <!-- ==========================  DARK MODE SCRIPT ============================= -->
    <script type="text/javascript">
        if (
            localStorage.theme === "dark" ||
            (!("theme" in localStorage) &&
                window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
            document.documentElement.classList.add("dark");
        } else {
            document.documentElement.classList.remove("dark");
        }
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PVY509PM3L"></script>
    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-PVY509PM3L');
    </script>
</head>

