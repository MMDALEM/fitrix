<div class="container" style="padding: 2rem 0;">
    <!-- Checkout Steps -->
    <div style="margin-bottom: 3rem;">
        <div style="display: flex; justify-content: center; align-items: center;">
            <div class="checkout-step active">
                <span class="step-number">1</span>
                <span class="step-title">سبد خرید</span>
            </div>
            <div class="step-line active"></div>
            <div class="checkout-step active">
                <span class="step-number">2</span>
                <span class="step-title">اطلاعات ارسال</span>
            </div>
            <div class="step-line"></div>
            <div class="checkout-step">
                <span class="step-number">3</span>
                <span class="step-title">پرداخت</span>
            </div>
            <div class="step-line"></div>
            <div class="checkout-step">
                <span class="step-number">4</span>
                <span class="step-title">تکمیل سفارش</span>
            </div>
        </div>
    </div>
    
    <form action="/checkout/process" method="POST" id="checkoutForm">
        <div style="display: grid; grid-template-columns: 1fr 400px; gap: 2rem;">
            <!-- Main Content -->
            <div>
                <!-- Shipping Information -->
                <div class="card" style="margin-bottom: 2rem;">
                    <div style="padding: 2rem;">
                        <h3 style="margin-bottom: 2rem; color: var(--dark-gray);">
                            <i class="fas fa-shipping-fast" style="color: var(--accent-orange);"></i>
                            اطلاعات ارسال
                        </h3>
                        
                        <% if (user) { %>
                            <!-- Saved Addresses -->
                            <div style="background: var(--light-gray); padding: 1rem; border-radius: 8px; margin-bottom: 2rem;">
                                <label style="display: flex; align-items: center; cursor: pointer;">
                                    <input type="radio" name="useAddress" value="saved" checked style="margin-left: 10px;">
                                    <div>
                                        <strong><%= user.firstName %> <%= user.lastName %></strong>
                                        <p style="color: #666; margin: 0.5rem 0;">
                                            <%= user.address.street || 'آدرس ثبت نشده' %><br>
                                            <%= user.address.city %>, <%= user.address.state %><br>
                                            تلفن: <%= user.phone %>
                                        </p>
                                    </div>
                                </label>
                            </div>
                            
                            <label style="display: block; margin-bottom: 1rem; cursor: pointer;">
                                <input type="radio" name="useAddress" value="new" style="margin-left: 10px;">
                                ارسال به آدرس جدید
                            </label>
                        <% } %>
                        
                        <div id="shippingForm" style="<%= user ? 'display: none;' : '' %>">
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div class="form-group">
                                    <label class="form-label">نام *</label>
                                    <input type="text" name="firstName" class="form-control" value="<%= user ? user.firstName : '' %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">نام خانوادگی *</label>
                                    <input type="text" name="lastName" class="form-control" value="<%= user ? user.lastName : '' %>" required>
                                </div>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div class="form-group">
                                    <label class="form-label">شماره موبایل *</label>
                                    <input type="tel" name="phone" class="form-control" value="<%= user ? user.phone : '' %>" placeholder="09123456789" required>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">ایمیل</label>
                                    <input type="email" name="email" class="form-control" value="<%= user ? user.email : '' %>">
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">آدرس کامل *</label>
                                <textarea name="street" class="form-control" rows="2" required><%= user && user.address ? user.address.street : '' %></textarea>
                            </div>
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                                <div class="form-group">
                                    <label class="form-label">استان *</label>
                                    <select name="state" class="form-control" required>
                                        <option value="">انتخاب کنید</option>
                                        <option value="تهران">تهران</option>
                                        <option value="اصفهان">اصفهان</option>
                                        <option value="فارس">فارس</option>
                                        <option value="خراسان رضوی">خراسان رضوی</option>
                                        <!-- Add more provinces -->
                                    </select>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">شهر *</label>
                                    <input type="text" name="city" class="form-control" value="<%= user && user.address ? user.address.city : '' %>" required>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">کد پستی</label>
                                    <input type="text" name="zipCode" class="form-control" value="<%= user && user.address ? user.address.zipCode : '' %>" pattern="[0-9]{10}">
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="form-label">یادداشت (اختیاری)</label>
                            <textarea name="notes" class="form-control" rows="2" placeholder="توضیحات تکمیلی برای ارسال..."></textarea>
                        </div>
                    </div>
                </div>
                
                <!-- Payment Method -->
                <div class="card">
                    <div style="padding: 2rem;">
                        <h3 style="margin-bottom: 2rem; color: var(--dark-gray);">
                            <i class="fas fa-credit-card" style="color: var(--accent-orange);"></i>
                            روش پرداخت
                        </h3>
                        
                        <div style="display: grid; gap: 1rem;">
                            <label class="payment-method">
                                <input type="radio" name="paymentMethod" value="online" checked>
                                <div class="payment-content">
                                    <i class="fas fa-credit-card"></i>
                                    <div>
                                        <strong>پرداخت آنلاین</strong>
                                        <p>پرداخت امن با کارت‌های بانکی</p>
                                    </div>
                                </div>
                            </label>
                            
                            <label class="payment-method">
                                <input type="radio" name="paymentMethod" value="cash">
                                <div class="payment-content">
                                    <i class="fas fa-money-bill"></i>
                                    <div>
                                        <strong>پرداخت در محل</strong>
                                        <p>پرداخت نقدی هنگام تحویل</p>
                                    </div>
                                </div>
                            </label>
                            
                            <label class="payment-method">
                                <input type="radio" name="paymentMethod" value="wallet">
                                <div class="payment-content">
                                    <i class="fas fa-wallet"></i>
                                    <div>
                                        <strong>کیف پول</strong>
                                        <p>موجودی: 0 تومان</p>
                                    </div>
                                </div>
                            </label>
                        </div>
                        
                        <!-- Bank Cards -->
                        <div id="onlinePayment" style="margin-top: 2rem;">
                            <p style="color: #666; margin-bottom: 1rem;">بانک‌های پشتیبانی شده:</p>
                            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                                <img src="https://via.placeholder.com/60x40?text=Mellat" alt="Bank" style="border: 1px solid #E0E0E0; border-radius: 4px;">
                                <img src="https://via.placeholder.com/60x40?text=Saman" alt="Bank" style="border: 1px solid #E0E0E0; border-radius: 4px;">
                                <img src="https://via.placeholder.com/60x40?text=Parsian" alt="Bank" style="border: 1px solid #E0E0E0; border-radius: 4px;">
                                <img src="https://via.placeholder.com/60x40?text=Melli" alt="Bank" style="border: 1px solid #E0E0E0; border-radius: 4px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Order Summary Sidebar -->
            <div>
                <div class="card" style="position: sticky; top: 90px;">
                    <div style="background: var(--primary-blue); color: white; padding: 1.5rem; border-radius: 12px 12px 0 0;">
                        <h3 style="margin: 0;">خلاصه سفارش</h3>
                    </div>
                    
                    <div style="padding: 1.5rem;">
                        <!-- Order Items -->
                        <div style="max-height: 300px; overflow-y: auto; margin-bottom: 1.5rem;">
                            <% if (cart && cart.items) { %>
                                <% cart.items.forEach(item => { %>
                                    <div style="display: flex; gap: 1rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #E0E0E0;">
                                        <img src="<%= item.product.images[0] || 'https://via.placeholder.com/60' %>" 
                                             alt="<%= item.product.name %>" 
                                             style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                        <div style="flex: 1;">
                                            <p style="font-weight: 600; margin-bottom: 0.25rem; font-size: 0.9rem;"><%= item.product.name %></p>
                                            <p style="color: #666; font-size: 0.85rem;">تعداد: <%= item.quantity %></p>
                                        </div>
                                        <div style="text-align: left;">
                                            <p style="font-weight: 600; color: var(--primary-blue);">
                                                <%= (item.product.currentPrice * item.quantity).toLocaleString('fa-IR') %>
                                            </p>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                        
                        <!-- Price Summary -->
                        <div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: #666;">قیمت کالاها:</span>
                                <strong><%= cart ? cart.total.toLocaleString('fa-IR') : '0' %> تومان</strong>
                            </div>
                            
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: #666;">تخفیف:</span>
                                <strong style="color: var(--success);">0 تومان</strong>
                            </div>
                            
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: #666;">هزینه ارسال:</span>
                                <strong>رایگان</strong>
                            </div>
                            
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: #666;">مالیات:</span>
                                <strong>0 تومان</strong>
                            </div>
                            
                            <hr style="margin: 1rem 0;">
                            
                            <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem;">
                                <span style="font-size: 1.2rem; font-weight: 600;">مبلغ قابل پرداخت:</span>
                                <strong style="font-size: 1.5rem; color: var(--primary-blue);">
                                    <%= cart ? cart.total.toLocaleString('fa-IR') : '0' %> تومان
                                </strong>
                            </div>
                        </div>
                        
                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-accent" style="width: 100%; font-size: 1.1rem; padding: 1rem;">
                            <i class="fas fa-lock"></i>
                            پرداخت و تکمیل سفارش
                        </button>
                        
                        <!-- Security Note -->
                        <div style="margin-top: 1rem; padding: 1rem; background: var(--light-gray); border-radius: 8px;">
                            <p style="font-size: 0.85rem; color: #666; margin: 0;">
                                <i class="fas fa-shield-alt" style="color: var(--success); margin-left: 5px;"></i>
                                پرداخت شما از طریق درگاه امن بانک انجام می‌شود
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
.checkout-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
}

.step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #E0E0E0;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    margin-bottom: 0.5rem;
}

.checkout-step.active .step-number {
    background: var(--primary-blue);
    color: white;
}

.step-title {
    font-size: 0.9rem;
    color: #666;
}

.checkout-step.active .step-title {
    color: var(--primary-blue);
    font-weight: 600;
}

.step-line {
    width: 100px;
    height: 2px;
    background: #E0E0E0;
    margin: 0 1rem;
    margin-bottom: 2rem;
}

.step-line.active {
    background: var(--primary-blue);
}

.payment-method {
    display: block;
    cursor: pointer;
    border: 2px solid #E0E0E0;
    border-radius: 12px;
    padding: 1rem;
    transition: all 0.3s;
}

.payment-method:hover {
    border-color: var(--primary-blue);
}

.payment-method input[type="radio"] {
    display: none;
}

.payment-method input[type="radio"]:checked + .payment-content {
    border-color: var(--primary-blue);
}

.payment-content {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.payment-content i {
    font-size: 1.5rem;
    color: var(--accent-orange);
}

.payment-content p {
    margin: 0.25rem 0 0 0;
    font-size: 0.85rem;
    color: #666;
}

.payment-method input[type="radio"]:checked + .payment-content {
    position: relative;
}

.payment-method input[type="radio"]:checked + .payment-content::after {
    content: '✓';
    position: absolute;
    top: -10px;
    left: -10px;
    background: var(--primary-blue);
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}
</style>

<script>
// Toggle shipping address form
if (document.querySelector('input[name="useAddress"]')) {
    document.querySelectorAll('input[name="useAddress"]').forEach(radio => {
        radio.addEventListener('change', function() {
            const shippingForm = document.getElementById('shippingForm');
            if (this.value === 'new') {
                shippingForm.style.display = 'block';
            } else {
                shippingForm.style.display = 'none';
            }
        });
    });
}

// Payment method toggle
document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
    radio.addEventListener('change', function() {
        const onlinePayment = document.getElementById('onlinePayment');
        if (this.value === 'online') {
            onlinePayment.style.display = 'block';
        } else {
            onlinePayment.style.display = 'none';
        }
    });
});

// Form validation
document.getElementById('checkoutForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Here you would normally process the payment
    alert('در حال انتقال به درگاه پرداخت...');
    
    // Simulate redirect to payment gateway
    setTimeout(() => {
        window.location.href = '/order-success';
    }, 2000);
});
</script>
