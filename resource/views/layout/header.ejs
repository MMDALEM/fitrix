<header class="header">
    <!-- Desktop -->
    <div class="container mt-5 hidden flex-col gap-y-6 lg:flex">
        <!-- TOPBAR -->
        <div class="flex-between">
            <!-- Search Box -->
            <div class="relative z-20">
                <form action="/shop" method="GET" class="flex gap-x-2 app-border bg-gray-50 dark:bg-gray-700 p-1 rounded-full ring-blue-400 w-84 transition-all">
                    <button type="submit" class="size-6 p-1.5 flex-center text-gray-100 bg-blue-600 rounded-full w-9 h-9">
                        <svg class="size-5">
                            <use href="#search" />
                        </svg>
                    </button>
                    <input name="search" placeholder="جستجو در فیت ریکس..." type="text" 
                        class="bg-transparent outline-none flex-1">
                </form>
            </div>

            <a href="/" class="flex flex-col text-center ml-20">
                <span class="font-MorabbaMedium text-4xl flex items-center">
                    <span class="text-blue-500">فیت ریکس</span> شاپ
                </span>
                <p class="font-DanaMedium text-gray-400">خرید ورزشی مکمل</p>
            </a>

            <!-- Action buttons... -->
        </div>

        <!-- NAVBAR -->
        <div class="relative flex-between h-16 bg-gray-900 dark:bg-gray-800 rounded-full text-gray-200 px-10">
            <ul class="flex items-center gap-x-8">
                <li class="menu-item">
                    <a href="/" class="menu-item_link">صفحه اصلی</a>
                </li>

                <!-- MEGA MENU با دسته‌بندی داینامیک -->
                <li class="menu-item megamenu-link">
                    <a href="/shop" class="menu-item_link flex items-center justify-center gap-x-1">
                        دسته بندی ها
                        <svg class="size-4">
                            <use href="#chevron" />
                        </svg>
                    </a>
                    <div class="megamenu">
                        <ul class="megamenu_category">
                            <% categories.forEach((cat, index) => { %>
                            <li class="megamenu_category-item" data-index="<%= index %>">
                                <a href="/shop?category=<%= cat.slug %>"><%= cat.title %></a>
                            </li>
                            <% }) %>
                        </ul>
                        <div class="megamenu_left">
                            <a href="/shop" class="text-blue-400 flex items-center gap-x-0.5 text-sm mb-4">
                                مشاهده همه
                                <svg class="size-4 rotate-90">
                                    <use href="#chevron" />
                                </svg>
                            </a>
                            
                            <!-- زیر دسته‌ها (اگه داری) -->
                            <% categories.forEach((cat, index) => { %>
                            <ul class="megamenu_left-item <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>">
                                <div class="megamenu_left-menu">
                                    <h2 class="megamenu_left-title"><%= cat.name %></h2>
                                    <% if (cat.children && cat.children.length > 0) { %>
                                        <% cat.children.forEach(child => { %>
                                        <li>
                                            <a href="/shop?category=<%= child._id %>"><%= child.name %></a>
                                        </li>
                                        <% }) %>
                                    <% } else { %>
                                    <li>
                                        <a href="/shop?category=<%= cat._id %>">مشاهده همه محصولات</a>
                                    </li>
                                    <% } %>
                                </div>
                            </ul>
                            <% }) %>
                        </div>
                    </div>
                </li>

                <li class="menu-item">
                    <a href="/shop" class="menu-item_link">فروشگاه</a>
                </li>
                <li class="menu-item">
                    <a href="/about" class="menu-item_link">درباره ما</a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Mobile -->
    <div class="flex justify-center lg:hidden">
        <!-- ... -->
        
        <!-- Search Modal موبایل -->
        <div class="mobile_search-modal">
            <div class="w-full flex items-center gap-x-2">
                <form action="/shop" method="GET" class="w-full flex items-center gap-x-1 bg-gray-200 dark:bg-gray-800 text-gray-500 py-2 px-4 rounded-3xl">
                    <svg class="size-6">
                        <use href="#search" />
                    </svg>
                    <input type="text" name="search" placeholder="جستجو در همه کالاها" class="bg-transparent outline-none flex-1">
                </form>
                <svg class="size-6 close-mobile_search-modal cursor-pointer">
                    <use href="#x-mark" />
                </svg>
            </div>
        </div>

        <!-- ... -->
    </div>
</header>

<script>
// مگامنو - نمایش زیردسته‌ها
document.querySelectorAll('.megamenu_category-item').forEach(item => {
    item.addEventListener('mouseenter', function() {
        const index = this.dataset.index;
        
        // حذف active از همه
        document.querySelectorAll('.megamenu_category-item').forEach(i => i.classList.remove('active'));
        document.querySelectorAll('.megamenu_left-item').forEach(i => i.classList.remove('active'));
        
        // اضافه کردن active
        this.classList.add('active');
        document.querySelector(`.megamenu_left-item[data-index="${index}"]`)?.classList.add('active');
    });
});
</script>