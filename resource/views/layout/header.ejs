<%
    let _items = (typeof basket !== 'undefined' && basket && basket.items)
        ? basket.items.filter(function (it) { return it.product; })
        : [];
    let _count = _items.reduce(function (s, i) { return s + i.quantity; }, 0);
    let _total = 0;
    _items.forEach(function (it) { _total += (it.product.priceSingle || 0) * it.quantity; });
%>

<!-- Header -->
<header class="header">
    <!-- Desktop -->
    <div class="container mt-5 hidden flex-col gap-y-6 lg:flex">
        <!-- TOPBAR -->
        <div class="flex-between">
            <!-- Search Box -->
            <div class="relative z-20">
                <div class="search-btn-open flex gap-x-2 app-border bg-gray-50 dark:bg-gray-700 p-1 rounded-full cursor-pointer ring-blue-400 w-84 transition-all">
                    <svg class="size-6 p-1.5 flex-center text-gray-100 bg-blue-600 rounded-full w-9 h-9"><use href="#search" /></svg>
                    <input placeholder="جستجو در فیت ریکس..." type="text">
                </div>
                <div class="search-modal space-y-4">
                    <div class="pt-4">
                        <span class="flex items-center gap-x-1 text-sm text-gray-500 dark:text-gray-200">
                            <svg class="size-4"><use href="#fire" /></svg>
                            <p>جستجو های پرطرفدار :</p>
                        </span>
                        <ul class="w-full flex items-center gap-1.5 mt-3 child:search-modal-list-item">
                            <li><a href="/shop?search=پروتئین">#پروتئین</a></li>
                            <li><a href="/shop?search=کراتین">#کراتین</a></li>
                            <li><a href="/shop?search=گینر">#گینر</a></li>
                            <li><a href="/shop?search=ویتامین">#ویتامین</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- Logo -->
            <a href="/" class="flex flex-col text-center ml-20">
                <span class="font-MorabbaMedium text-4xl flex items-center">
                    <span class="text-blue-500">فیت ریکس</span> شاپ
                </span>
                <p class="font-DanaMedium text-gray-400"> لوازم ورزشی </p>
            </a>
            <!--  Action -->
            <div class="flex items-center gap-x-3">
                <% if (typeof user !== 'undefined' && user) { %>
                    <button class="group relative flex-center py-2 px-4 app-border rounded-full app-hover delay-75">
                        <a href="/dashboard" class="flex items-center gap-x-1">
                            <svg class="size-5"><use href="#user" /></svg>
                            <p>حساب کاربری</p>
                        </a>
                        <div class="absolute dark:border-none border border-gray-100 w-52 p-2 bg-white text-gray-900 dark:text-gray-100 flex flex-col gap-y-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-hover:top-12 transition-all delay-100 dark:bg-gray-700 top-20 rounded-lg text-base shadow child:transition-all duration-300 child:py-1.5 child:px-2 z-30 child:rounded-lg child:w-full">
                            <a href="/dashboard" class="flex items-center gap-x-2 hover:bg-blue-500 hover:text-gray-100">
                                <svg class="h-5 w-5"><use href="#user"></use></svg>
                                سفارشات من
                            </a>
                            <a href="/dashboard/address" class="flex items-center gap-x-2 hover:bg-blue-500 hover:text-gray-100">
                                <svg class="h-5 w-5"><use href="#cog"></use></svg>
                                اطلاعات کاربری
                            </a>
                            <a href="/logout" class="flex items-center gap-x-2 hover:bg-red-500 dark:hover:bg-red-500 hover:text-gray-100">
                                <svg class="h-5 w-5"><use href="#arrow-left-end"></use></svg>
                                خروج از حساب
                            </a>
                        </div>
                    </button>
                <% } else { %>
                    <button class="flex-center py-2 px-4 app-border rounded-full app-hover">
                        <a href="/auth" class="flex items-center gap-x-2">
                            <p>ورود | ثبت‌نام</p>
                            <svg class="size-5"><use href="#arrow-left-end" /></svg>
                        </a>
                    </button>
                <% } %>

                <button class="toggle-theme flex-center p-2 app-border rounded-full app-hover">
                    <svg class="inline-block dark:hidden size-6"><use href="#moon" /></svg>
                    <svg class="hidden dark:inline size-6"><use href="#sun" /></svg>
                </button>


                <!-- Shopping cart button -->
                <button class="flex-center p-2 bg-blue-600 text-gray-100 rounded-full open-cart relative">
                    <svg class="size-6"><use href="#shopping-bag" /></svg>
                    <span id="headerCartBadge" class="absolute -top-1 -right-1 flex h-4 w-4 <%= _count > 0 ? '' : 'hidden' %>">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-600 opacity-75"></span>
                        <span id="headerCartCount" class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-xs pt-1 flex-center text-white"><%= _count.toLocaleString('fa-IR') %></span>
                    </span>
                </button>

                <!-- Cart dropdown -->
                <div class="cart">
                    <div class="flex items-center justify-between pb-2 border-b-2 border-gray-200 dark:border-gray-600 text-gray-800 dark:text-gray-300">
                        <h2 class="font-DanaMedium text-lg">سبد خرید
                            <span class="text-sm text-gray-400 font-Dana cart-count-label">(<%= _count.toLocaleString('fa-IR') %> مورد)</span>
                        </h2>
                        <svg class="size-5 cursor-pointer close-cart mb-.5"><use href="#x-mark" /></svg>
                    </div>

                    <% if (_items.length === 0) { %>
                        <div class="cart-empty flex flex-col items-center justify-center py-10 gap-y-3 text-gray-400">
                            <svg class="size-12"><use href="#shopping-bag"></use></svg>
                            <p class="text-sm">سبد خرید شما خالی است</p>
                        </div>
                    <% } else { %>
                        <div class="flex flex-col divide-y-2 divide-gray-200 dark:divide-gray-600 my-4">
                            <% _items.forEach(function (item) { %>
                                <% var p = item.product; %>
                                <div class="grid grid-cols-12 gap-x-2 w-full py-4">
                                    <div class="col-span-4 w-24 h-20">
                                        <img src="<%= p.image %>" class="rounded-lg w-full h-full mx-auto" style="object-fit: contain;" alt="<%= p.title %>">
                                    </div>
                                    <div class="col-span-8 flex flex-col justify-between">
                                        <a href="/product/<%= p.slug %>" class="font-DanaMedium line-clamp-2 hover:text-blue-500"><%= p.title %></a>
                                        <div class="flex items-center justify-between gap-x-2 mt-2">
                                            <span class="text-sm text-gray-500">تعداد: <%= item.quantity.toLocaleString('fa-IR') %></span>
                                            <p class="text-lg text-blue-500 dark:text-blue-400 font-DanaMedium">
                                                <%= ((p.priceSingle || 0) * item.quantity).toLocaleString('fa-IR') %>
                                                <span class="font-Dana text-sm">تومان</span>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <div class="w-[90%] fixed bottom-2 flex items-center justify-between border-t-2 border-gray-200 dark:border-gray-600 pt-4">
                            <div>
                                <p class="text-gray-500 dark:text-gray-300 text-sm">مبلغ قابل پرداخت :</p>
                                <p class="text-lg text-blue-500 dark:text-blue-400 font-DanaDemiBold">
                                    <%= _total.toLocaleString('fa-IR') %>
                                    <span class="font-Dana text-sm">تومان</span>
                                </p>
                            </div>
                            <a href="/basket" class="py-2 px-4 bg-blue-600 flex-center hover:bg-blue-700 transition-all rounded-lg text-gray-200">ثبت سفارش</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
        <!-- NAVBAR -->
        <div class="relative flex-between h-16 bg-gray-900 dark:bg-gray-800 rounded-full text-gray-200 px-10">
            <ul class="flex items-center gap-x-8">
                <li class="menu-item"><a href="/" class="menu-item_link">صفحه اصلی</a></li>
                <li class="menu-item megamenu-link">
                    <a class="menu-item_link flex items-center justify-center gap-x-1">
                        دسته بندی ها
                        <svg class="size-4"><use href="#chevron" /></svg>
                    </a>
                    <div class="megamenu">
                        <ul class="megamenu_category">
                            <% categories.forEach(function (category) { %>
                                <li class="megamenu_category-item">
                                    <a href="/shop?category=<%= category.slug %>"><%= category.title %></a>
                                    <% if (category.subCategories && category.subCategories.length) { %>
                                        <ul class="mt-1 mr-3 space-y-1">
                                            <% category.subCategories.forEach(function (sub) { %>
                                                <li>
                                                    <a href="/shop?category=<%= sub.slug %>" class="text-sm text-gray-400 hover:text-blue-400 transition-colors">
                                                        <%= sub.title %>
                                                    </a>
                                                </li>
                                            <% }); %>
                                        </ul>
                                    <% } %>
                                </li>
                            <% }); %>
                        </ul>
                        <div class="megamenu_left">
                            <a href="/shop" class="text-blue-400 flex items-center gap-x-0.5 text-sm mb-4">
                                مشاهده همه
                                <svg class="size-4 rotate-90"><use href="#chevron" /></svg>
                            </a>
                            <% if (typeof brands !== 'undefined' && brands) { %>
                                <h2 class="megamenu_left-title">برندها :</h2>
                                <div class="megamenu_brands">
                                    <% brands.forEach(function (brand) { %>
                                        <a href="/shop?brand=<%= brand.slug %>" class="text-blue-400 flex items-center gap-x-0.5 text-sm mb-4"><%= brand.title %></a>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </li>
                <li class="menu-item"><a href="/shop" class="menu-item_link">فروشگاه</a></li>
                <li class="menu-item"><a href="#about" class="menu-item_link">درباره ما</a></li>
            </ul>
            <div class="relative">
                <button class="flex items-center gap-x-1 citylist-open">
                    <svg class="size-6"><use href="#map" /></svg>
                    <p>ایران</p>
                </button>
            </div>
        </div>
    </div>
    <!-- Mobile -->
    <div class="flex justify-center lg:hidden">
        <!-- Top Navbar -->
        <nav
            class="absolute top-0 inset-x-0 w-full h-16 px-4 shadow-sm dark:bg-gray-800 flex items-center justify-between">
            <!-- Menu -->
            <button class="open-menu-mobile flex-center p-2 app-border rounded-full">
                <svg class=" size-6">
                    <use href="#bars" />
                </svg>
            </button>
            <div class="mobile-menu z-50 flex flex-col">
                <!--  MENU MOBILE header -->
                <div class="flex w-full items-center justify-between border-b-normal pb-4">
                    <a href="/" class="flex flex-col text-center ml-5">
                        <span class="font-MorabbaMedium text-2xl flex items-center">
                            <span class="text-blue-500">فیت ریکس</span> شاپ
                        </span>
                    </a>
                    <button class="close-menu-mobile">
                        <svg class="size-5 text-gray-500 dark:text-gray-200">
                            <use href="#x-mark" />
                        </svg>
                    </button>
                </div>
                <!-- MENU MOBILE CATEGORY & ACTION  -->
                <ul class="flex flex-col gap-y-2 text-gray-800 dark:text-gray-100 mt-4">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <button class="group relative flex-center py-2 px-4 app-border rounded-full app-hover delay-75">
                            <a href="/dashboard" class="flex items-center gap-x-1">
                                <svg class="size-5"><use href="#user" /></svg>
                                <p>حساب کاربری</p>
                            </a>
                        </button>
                    <% } else { %>
                        <button class="flex-center py-2 px-4 app-border rounded-full app-hover">
                            <a href="/auth" class="flex items-center gap-x-2">
                                <p>ورود | ثبت‌نام</p>
                                <svg class="size-5"><use href="#arrow-left-end" /></svg>
                            </a>
                        </button>
                    <% } %>
                    <li>
                        <span class="open-category mobile-menu-item">
                            <svg class="size-5"><use href="#squares" /></svg>
                            <span>دسته بندی</span>
                        </span>
                        <div class="category-slide">
                            <div class="w-full border-b-normal pb-4">
                                <span class="close-category-slide flex items-center gap-x-1 cursor-pointer">
                                    <svg class="size-4"><use href="#arrow" /></svg>
                                    دسته بندی
                                </span>
                            </div>
                            <ul class="child:flex pt-4 child:cursor-pointer space-y-2">
                                <% categories.forEach(function (category) { %>
                                    <li>
                                        <span style="position: static !important; width: 100vw;" class="mobile-menu-category-badge">
                                            <a href="/shop?category=<%= category.slug %>"><%= category.title %></a>
                                        </span>
                                    </li>
                                    <% if (category.subCategories && category.subCategories.length) { %>
                                        <% category.subCategories.forEach(function (sub) { %>
                                            <li class="mr-5">
                                                <a href="/shop?category=<%= sub.slug %>" class="text-sm text-gray-500 dark:text-gray-300">
                                                    <%= sub.title %>
                                                </a>
                                            </li>
                                        <% }) %>
                                    <% } %>
                                <% }) %>
                            </ul>
                        </div>
                    </li>
                    <li class="mobile-menu-item">
                        <svg class="size-5"><use href="#shopping-cart" /></svg>
                        <a href="/shop">فروشگاه</a>
                    </li>
                    <li class="mobile-menu-item">
                        <svg class="size-5"><use href="#user" /></svg>
                        <a href="/dashboard">حساب کاربری</a>
                    </li>
                    <li class="mobile-menu-item">
                        <svg class="size-5"><use href="#shopping-cart" /></svg>
                        <a href="/basket">سبد خرید</a>
                    </li>
                    <li class="mobile-menu-item">
                        <svg class="size-5"><use href="#check-badge" /></svg>
                        <a href="#about">دربـاره مـا</a>
                    </li>
                    <li class="mobile-menu-item">
                        <svg class="size-5"><use href="#phone" /></svg>
                        <a href="#contact">تـماس بـا مـا</a>
                    </li>
                </ul>
            </div>
            <!-- Logo -->
            <div class="col-span-4 w-26 h-15">
                <a href="/" class="flex flex-col text-center ml-5">
                    <span class="font-MorabbaMedium text-2xl flex items-center">
                        <span class="text-blue-500">فیت ریکس</span> شاپ
                    </span>
                    <p class="font-DanaMedium text-gray-400"> لوازم ورزشی </p>
                </a>
            </div>
            <!-- Toggle theme -->

            <div class="flex items-center gap-x-2">
                <a href="/basket" style="background-color: rgb(37 99 235 / var(--tw-bg-opacity, 1));" class="relative flex-center p-2 app-border rounded-full">
                    <svg class="size-6"><use href="#shopping-bag" /></svg>
                    <span id="headerCartBadge" class="absolute -top-1 -right-1 flex h-4 w-4 <%= _count > 0 ? '' : 'hidden' %>">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-600 opacity-75"></span>
                        <span id="headerCartCount" class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-xs pt-1 flex-center text-white"><%= _count.toLocaleString('fa-IR') %></span>
                    </span>
                </a>
                <button class="toggle-theme flex-center p-2 app-border rounded-full">
                    <svg class="inline-block dark:hidden size-5"><use href="#moon" /></svg>
                    <svg class="hidden dark:inline size-5"><use href="#sun" /></svg>
                </button>
            </div>
        </nav>
        <!-- Search baer -->
        <button class="open-mobile_search-modal">
            <svg class=" size-6">
                <use href="#search" />
            </svg>
            <p>جستجو در <span class="font-MorabbaMedium">فیت‌ریکس شاپ</span></p>
        </button>
        <!-- Search Moadal -->
        <div class="mobile_search-modal">
            <!-- TOP -->
            <div class="w-full flex items-center gap-x-2">
                <button
                    class="w-full flex items-center gap-x-1 bg-gray-200 dark:bg-gray-800 text-gray-500 py-2 px-4 rounded-3xl">
                    <svg class="size-6">
                        <use href="#search" />
                    </svg>
                    <input type="text" placeholder="جستجو در همه محصولات">
                </button>
                <svg class="size-6 close-mobile_search-modal">
                    <use href="#x-mark" />
                </svg>
            </div>
            <div class="w-full space-y-4">
                <!-- Trend -->
                <div class="pt-4">
                    <span class="flex items-center gap-x-1 text-sm text-gray-500 dark:text-gray-200">
                        <svg class="size-4">
                            <use href="#fire" />
                        </svg>
                        <p>جستجو های پرطرفدار :</p>
                    </span>
                    <ul class="w-full flex items-center gap-1.5 mt-3 child:search-modal-list-item">
                        <li>
                            <a href="/shop?search=وی">#وی</a>
                        </li>
                        <li>
                            <a href="/shop?search=کراتین">#کراتین</a>
                        </li>
                        <li>
                            <a href="/shop?search=گینر">#گینر</a>
                        </li>
                        <li>
                            <a href="/shop?search=گلوتامین">#گلوتامین</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <!-- bottom Navbar-->
        <ul class="bottom-navbar">
            <li class="dark:text-sky-400 text-blue-500 font-DanaMedium">
                <svg class="size-5">
                    <use href="#home" />
                </svg>
                <a href="/">خانه</a>
            </li>
            <li>
                <svg class="size-5">
                    <use href="#squares" />
                </svg>
                <a href="/shop">فروشگاه</a>
            </li>
            <li>
                <svg class="size-5">
                    <use href="#shopping-bag" />
                </svg>
                <a href="/basket">سبد خرید</a>
            </li>
            <li>
                <svg class="size-5">
                    <use href="#user" />
                </svg>
                <a href="/dashboard">حساب من</a>
            </li>
        </ul>
    </div>
</header>

<script>
    window.updateCartCount = function (count) {
        const badge = document.getElementById("headerCartBadge");
        const countEl = document.getElementById("headerCartCount");
        const label = document.querySelector(".cart-count-label");
        const n = Number(count) || 0;
        const fa = n.toLocaleString("fa-IR");

        if (countEl) countEl.textContent = fa;
        if (label) label.textContent = "(" + fa + " مورد)";
        if (badge) {
            if (n > 0) badge.classList.remove("hidden");
            else badge.classList.add("hidden");
        }
    };
</script>