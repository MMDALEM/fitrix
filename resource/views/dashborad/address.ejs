<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>آدرس های من</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @font-face {
      font-family: 'Dana';
      src: local('Dana');
    }

    @font-face {
      font-family: 'DanaMedium';
      src: local('Dana Medium');
    }

    .font-Dana {
      font-family: 'Dana', sans-serif;
    }

    .font-DanaMedium {
      font-family: 'DanaMedium', sans-serif;
    }

    @keyframes fade-in {
      from {
        opacity: 0;
        transform: scale(0.95);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    .animate-fade-in {
      animation: fade-in 0.2s ease-out;
    }

    @keyframes slide-up {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-slide-up {
      animation: slide-up 0.3s ease-out;
    }
  </style>
</head>

<body class="bg-gray-100 dark:bg-gray-900 text-gray-800 dark:text-white min-h-screen font-Dana">

  <main class="container relative mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-x-8 mt-10">
      <!-- SIDE MENU -->
        <div class="lg:sticky mb-8 top-1 h-fit lg:w-1/4 hidden lg:flex flex-col gap-y-4 items-center shadow rounded-lg p-4 dark:bg-gray-800 bg-white">
             <!-- NAME AND AVATAR  -->
             <div class="w-full flex items-center justify-between border-b border-gray-200 dark:border-white/20 py-3">
                <div class="flex items-center gap-x-3">
                    <img src="/images/svg/user.png" class="size-10 ring-2 ring-gray-400/20 rounded-full"
                        alt="AVATAR">
                    <span class="felx flex-col gap-y-2">
                        <p class="font-DanaMedium text-lg">
                            <% if(user?.firstName && user?.lastName){ %>
                                <%= user?.firstName %><%= user?.lastName %>
                            <% }else{ %>
                                کاربر گرامی
                            <% } %>
                        </p>
                        <p class="text-gray-400"><%= user?.phone %></p>
                    </span>
                </div>
                <span>
                    <svg class="w-6 h-6 cursor-pointer text-blue-500">
                        <use href="#edit"></use>
                    </svg>
                </span>
            </div> 
            <ul
            class="w-full relative space-y-2 child:duration-300 child:transition-all child:py-3  child:px-2 child:flex child:gap-x-2 text-lg child:cursor-pointer child:rounded-lg">
            <li class="bg-blue-500/10 text-blue-500">
                <svg class="w-6 h-6 ">
                    <use href="#squares"></use>
                </svg>
                <a href="/dashboard">داشبورد</a>
            </li>
            <li class="hover:text-blue-500">
                <svg class="w-6 h-6 ">
                    <use href="#shopping-bag"></use>
                </svg>
                <a href="/dashboard">
                    سفارش ها
                </a>
            </li>
            <li class="hover:text-blue-500">
                <svg class="w-6 h-6 ">
                    <use href="#map"></use>
                </svg>
                <a href="/dashboard/address">آدرس ها</a>
            </li>
            <li class="hover:text-blue-500">
                <svg class="w-6 h-6 ">
                    <use href="#cog"></use>
                </svg>
                <a href="/dashboard">اطلاعات حساب </a>
            </li>
            <li class="text-red-400">
                <svg class="w-6 h-6 ">
                    <use href="#arrow-left-end"></use>
                </svg>
                <a href="/logout">خروج</a>
            </li>
        </ul>
        </div>

      <!-- محتوای اصلی -->
      <div class="lg:w-3/4">
        <div class="flex flex-col shadow rounded-lg p-4 dark:bg-gray-800 bg-white mt-5 lg:mt-0">
          <div class="flex items-center justify-between">
            <span class="flex items-center gap-x-2">
              <h2 class="font-DanaMedium text-lg">آدرس های من</h2>
            </span>
            <!-- دکمه افزودن آدرس جدید -->
            <button id="openModalBtn" class="flex items-center gap-x-1 text-blue-500 hover:text-blue-600 transition-colors">
              <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              <h2 class="font-DanaMedium">آدرس جدید</h2>
            </button>
          </div>

          <!-- لیست آدرس‌ها -->
          <ul class="mt-5 space-y-3">
          <% addresses.forEach(address => { %>
            <li class="relative w-full border border-blue-300 dark:border-blue-400 p-4 rounded-lg animate-slide-up">
              <span class="flex items-center gap-x-1 text-blue-500 dark:text-blue-400">
                <span><p>عنوان : <%= address.title %></p></span>
                <h2 class="font-DanaMedium"></h2>
              </span>
              <div class="space-y-1.5 text-gray-600 dark:text-gray-300 mt-3 mr-2">
                <p>آدرس : <%= address.address %></p>
                <p>کد پستی: <%= address.postalCode %></p>
                <p>گیرنده: <%= address.receiver %></p>
                <p>تلفن: <%= address.phone %></p>
              </div>
              <span class="absolute left-4 bottom-3 flex items-center gap-x-4">
                <form method="POST" action="/dashboard/address/<%= address.id %>">
                    <button class="text-red-500 hover:text-red-600 transition-colors">
                    <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    </button>
                </form>
              </span>
            </li>
           <% }) %>
          </ul>

          <!-- پیام خالی بودن لیست -->
          <div id="emptyState" class="hidden flex-col items-center justify-center py-10 text-gray-400">
            <svg class="size-16 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="font-DanaMedium">هنوز آدرسی ثبت نشده است</p>
            <p class="text-sm mt-1">برای افزودن آدرس جدید کلیک کنید</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Modal آدرس جدید -->
  <div id="addressModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl w-full max-w-md mx-4 p-6 animate-fade-in">
      <!-- هدر -->
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-DanaMedium text-lg"> افزودن آدرس جدید</h3>
        <button id="closeModalBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors">
          <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- فرم -->
      <form method="post" action="/dashboard/address" class="space-y-4">
        <div>
          <label class="block text-sm font-DanaMedium mb-1.5">عنوان آدرس</label>
          <input type="text" name="title" placeholder="مثلاً: منزل، محل کار" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>

        <div>
          <label class="block text-sm font-DanaMedium mb-1.5">آدرس کامل</label>
          <textarea name="address" rows="3" placeholder="استان، شهر، خیابان، کوچه، پلاک..." required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none resize-none transition-all"></textarea>
        </div>

        <div>
          <label class="block text-sm font-DanaMedium mb-1.5">کد پستی</label>
          <input type="text" name="postalCode" placeholder="کد پستی ۱۰ رقمی" maxlength="10" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        </div>

        <div>
          <label class="block text-sm font-DanaMedium mb-1.5">نام گیرنده</label>
          <input type="text" name="receiver" placeholder="نام و نام خانوادگی گیرنده" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>

        <div>
          <label class="block text-sm font-DanaMedium mb-1.5">شماره تماس</label>
          <input type="tel" name="phone" placeholder="شماره موبایل گیرنده" maxlength="11" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
        </div>

        <div class="flex gap-x-3 pt-3">
          <button type="submit" id="submitBtn" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white font-DanaMedium py-2.5 rounded-lg transition-colors flex items-center justify-center gap-x-2">
            <span>ذخیره آدرس</span>
            <svg id="loadingSpinner" class="hidden size-5 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
          <button type="button" id="cancelBtn" class="flex-1 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 font-DanaMedium py-2.5 rounded-lg transition-colors">
            انصراف
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast Notification -->
  <div id="toast" class="fixed bottom-5 left-5 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transform translate-y-20 opacity-0 transition-all duration-300 z-50">
    <span id="toastMessage">آدرس با موفقیت ذخیره شد</span>
  </div>

  <script>
    // Elements
    const modal = document.getElementById('addressModal');
    const openBtn = document.getElementById('openModalBtn');
    const closeBtn = document.getElementById('closeModalBtn');
    const cancelBtn = document.getElementById('cancelBtn');
    const form = document.getElementById('addressForm');
    const addressList = document.getElementById('addressList');
    const emptyState = document.getElementById('emptyState');
    const submitBtn = document.getElementById('submitBtn');
    const loadingSpinner = document.getElementById('loadingSpinner');
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toastMessage');

    // نمایش Toast
    function showToast(message, isError = false) {
      toastMessage.textContent = message;
      toast.classList.remove('bg-green-500', 'bg-red-500');
      toast.classList.add(isError ? 'bg-red-500' : 'bg-green-500');
      toast.classList.remove('translate-y-20', 'opacity-0');

      setTimeout(() => {
        toast.classList.add('translate-y-20', 'opacity-0');
      }, 3000);
    }

    // باز کردن modal
    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    // بستن modal
    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
      form.reset();
    }

    // Event Listeners
    openBtn.addEventListener('click', () => {
      editingIndex = -1;
      openModal();
    });

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);

    // بستن با کلیک روی backdrop
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // بستن با Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

  </script>