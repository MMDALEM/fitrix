<link rel="stylesheet" href="/styles/address.css">

<main class="container relative mx-auto px-4">      
    <div class="flex flex-col lg:flex-row gap-x-8 mt-10">
        <!-- SIDE MENU -->
        <div class="lg:sticky mb-8 top-1 h-fit lg:w-1/4 hidden lg:flex flex-col gap-y-4 items-center shadow rounded-lg p-4 dark:bg-gray-800 bg-white">
            <!-- محتوای منوی سمت چپ -->
            <div class="w-full flex items-center justify-between border-b border-gray-200 dark:border-white/20 py-3">
                <div class="flex items-center gap-x-3">
                    <div class="size-10 ring-2 ring-gray-400/20 rounded-full bg-blue-500"></div>
                    <span class="flex flex-col gap-y-2">
                        <p class="font-DanaMedium text-lg">پارسا وصالی</p>
                        <p class="text-gray-400">09100000001</p>
                    </span>
                </div>
            </div> 
        </div>

        <!-- محتوای اصلی -->
        <div class="lg:w-3/4">
           <div class="flex flex-col shadow rounded-lg p-4 dark:bg-gray-800 bg-white mt-5 lg:mt-0">
            <div class="flex items-center justify-between">
                <span class="flex items-center gap-x-2">
                    <h2 class="font-DanaMedium text-lg">📍 آدرس های من:</h2>
                </span>
                <!-- دکمه افزودن آدرس جدید -->
                <button id="openModalBtn" class="flex items-center gap-x-1 text-blue-500 hover:text-blue-600 transition-colors">
                    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    <h2 class="font-DanaMedium">آدرس جدید</h2>
                </button>
            </div>

            <!-- لیست آدرس‌ها -->
            <ul id="addressList" class="mt-5 space-y-3">
                <li class="relative w-full border border-blue-300 dark:border-blue-400 p-4 rounded-lg">
                    <span class="flex items-center gap-x-1 text-blue-500 dark:text-blue-400">
                        <span class="text-xl">📍</span>
                        <h2 class="font-DanaMedium">آدرس منزل</h2>
                    </span>
                    <div class="space-y-1.5 text-gray-600 dark:text-gray-300 mt-3 mr-2">
                        <p>استان تهران-بلوار آزادی، خیابان استاد معین، کوچه گلستان، پلاک ۱۰</p>
                        <p>کد پستی: 000000000</p>
                        <p>گیرنده: پارسا وصالی</p>
                    </div>
                    <span class="absolute left-4 bottom-3 flex items-center gap-x-4">
                        <button class="text-blue-500 hover:text-blue-600">
                            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                            </svg>
                        </button>
                        <button class="text-red-500 hover:text-red-600">
                            <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                        </button>
                    </span>
                </li>
            </ul>
           </div>
        </div>
    </div>
</main>

<!-- مودال افزودن آدرس جدید -->
<div id="addressModal" class="modal">
    <div class="modal-content bg-white dark:bg-gray-800 rounded-lg shadow-xl w-full max-w-2xl mx-4 max-h-[90vh] overflow-y-auto">
        <!-- هدر مودال -->
        <div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
            <h3 class="text-xl font-DanaMedium">افزودن آدرس جدید</h3>
            <button id="closeModalBtn" class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
                <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- فرم افزودن آدرس -->
        <div class="p-6">
            <div class="space-y-4">
                <!-- نام آدرس -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">نام آدرس (مثال: منزل، محل کار)</label>
                    <input type="text" id="addressName" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="نام آدرس را وارد کنید">
                </div>

                <!-- استان -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">استان</label>
                    <input type="text" id="province" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="نام استان">
                </div>

                <!-- شهر -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">شهر</label>
                    <input type="text" id="city" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="نام شهر">
                </div>

                <!-- آدرس کامل -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">آدرس کامل</label>
                    <textarea id="fullAddress" rows="3" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="خیابان، کوچه، پلاک و ..."></textarea>
                </div>

                <!-- کد پستی -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">کد پستی (بدون خط تیره)</label>
                    <input type="text" id="postalCode" maxlength="10" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="0000000000">
                </div>

                <!-- نام گیرنده -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">نام و نام خانوادگی گیرنده</label>
                    <input type="text" id="recipient" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="نام گیرنده">
                </div>

                <!-- شماره تماس -->
                <div>
                    <label class="block text-sm font-DanaMedium mb-2">شماره تماس</label>
                    <input type="tel" id="phone" maxlength="11" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700" placeholder="09xxxxxxxxx">
                </div>
            </div>

            <!-- دکمه‌های عملیات -->
            <div class="flex gap-3 mt-6">
                <button id="saveAddressBtn" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-lg font-DanaMedium transition-colors">
                    ذخیره آدرس
                </button>
                <button id="cancelBtn" class="flex-1 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 py-3 rounded-lg font-DanaMedium transition-colors">
                    انصراف
                </button>
            </div>
        </div>
    </div>
</div>


<script src="/scripts/dashboard.js"></script>
<script src="/js/address.js"></script>
<script src="https://cdn.tailwindcss.com"></script>