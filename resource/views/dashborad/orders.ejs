<style>
    button {
        padding: 0.625rem 1.5rem !important;
    }
</style>

<main class="container relative">
  <div class="flex flex-col lg:flex-row gap-x-8 mt-10">
    <!-- منوی مشترک داشبورد -->
        <div class="lg:sticky mb-8 top-1 h-fit lg:w-1/4 hidden lg:flex flex-col gap-y-4 items-center shadow rounded-lg p-4 dark:bg-gray-800 bg-white">
             <!-- NAME AND AVATAR  -->
             <div class="w-full flex items-center justify-between border-b border-gray-200 dark:border-white/20 py-3">
                <div class="flex items-center gap-x-3">
                    <img src="/images/svg/user.png" class="size-10 ring-2 ring-gray-400/20 rounded-full"
                        alt="AVATAR">
                    <span class="felx flex-col gap-y-2">
                        <p class="font-DanaMedium text-lg">
                            <% if(user?.firstName && user?.lastName){ %>
                                <%= user?.firstName %><%= user?.lastName %>
                            <% }else{ %>
                                کاربر گرامی
                            <% } %>
                        </p>
                        <p class="text-gray-400"><%= user?.phone %></p>
                    </span>
                </div>
            </div> 
            <ul
                class="w-full relative space-y-2 child:duration-300 child:transition-all child:py-3  child:px-2 child:flex child:gap-x-2 text-lg child:cursor-pointer child:rounded-lg">
                <li <% if (req.path === '/') { %> class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard">
                    <svg class="w-6 h-6 ">
                        <use href="#squares"></use>
                    </svg>
                    </a>
                    <a href="/dashboard">داشبورد</a>
                </li>
                <li <% if (req.path === '/orders') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                <a href="/dashboard/orders">
                    <svg class="w-6 h-6 ">
                        <use href="#shopping-bag"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/orders">سفارش ها</a>
                </li>
                <li <% if (req.path === '/address') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard/address">
                    <svg class="w-6 h-6 ">
                        <use href="#map"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/address">آدرس ها</a>
                </li>
                <li <% if (req.path === '/mine') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/program/mine">
                    <svg class="w-6 h-6 ">
                        <use href="#document"></use>
                    </svg>
                    </a>
                    <a href="/program/mine">برنامه‌های من</a>
                </li>
                <li <% if (req.path === '/account') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard/account">
                    <svg class="w-6 h-6 ">
                        <use href="#cog"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/account">اطلاعات حساب </a>
                </li>
                <li class="text-red-400">
                    <a href="/logout">
                    <svg class="w-6 h-6 ">
                        <use href="#arrow-left-end"></use>
                    </svg>
                    </a>
                    <a href="/logout">خروج</a>
                </li>
            </ul>
        </div>

    <div class="lg:w-3/4">
      <div class="flex flex-col shadow rounded-lg p-4 dark:bg-gray-800 bg-white">
        <div class="flex items-center gap-x-2 border-b border-gray-200 dark:border-white/20 pb-3">
          <svg class="size-7 text-blue-500"><use href="#shopping-bag"></use></svg>
          <h2 class="font-DanaMedium text-lg">سفارش‌های من</h2>
          <span class="text-gray-400 text-sm">(<%= Number(orders.length).toLocaleString('fa-IR') %> سفارش)</span>
        </div>

        <% if (!orders.length) { %>
        <div class="flex flex-col items-center justify-center py-14 text-gray-400">
          <svg class="size-16 mb-3"><use href="#shopping-bag"></use></svg>
          <p class="font-DanaMedium">هنوز سفارشی ثبت نکرده‌اید</p>
          <a href="/shop" class="mt-4 bg-blue-500 hover:bg-blue-600 text-white rounded-lg px-5 py-2 text-sm">شروع خرید</a>
        </div>
        <% } %>

        <ul class="mt-4 space-y-4">
          <% orders.forEach(function (o) { %>
          <li class="border border-gray-200 dark:border-white/15 rounded-xl p-4 hover:border-blue-300 transition-colors">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div class="flex items-center gap-x-2">
                <span class="font-DanaMedium">سفارش</span>
                <span class="text-blue-500 font-DanaMedium">#<%= o.orderNumber || '—' %></span>
              </div>
              <span class="text-xs px-2.5 py-1 rounded-full
                <%= o.status === 'cancelled' ? 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-300'
                    : (o.isShipped ? 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-300'
                    : 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-300') %>">
                <%= o.statusLabel || (o.status === 'paid' ? 'پرداخت شده' : o.status) %>
              </span>
            </div>

            <div class="flex items-center gap-2 mt-3 flex-wrap">
              <% (o.items || []).slice(0, 5).forEach(function (it) { %>
                <% if (it.product && it.product.image) { %>
                <img src="<%= it.product.image %>" class="size-12 w-10 rounded-lg object-contain dark:border-white/10" alt="">
                <% } %>
              <% }) %>
              <% if ((o.items || []).length > 5) { %>
              <span class="text-gray-400 text-sm">+<%= Number(o.items.length - 5).toLocaleString('fa-IR') %></span>
              <% } %>
            </div>

            <div class="flex flex-wrap items-center justify-between gap-2 mt-3 text-sm text-gray-500 dark:text-gray-300">
              <div class="flex items-center gap-x-4">
                <span><%= o.paidAt ? date(o.paidAt).format('jYYYY/jMM/jDD') : (date(o.createdAt).format('jYYYY/jMM/jDD')) %></span>
                <span><%= Number((o.items||[]).reduce(function(s,i){return s+(i.quantity||0)},0)).toLocaleString('fa-IR') %> کالا</span>
              </div>
              <div class="flex items-center gap-x-3">
                <span class="font-DanaMedium text-gray-800 dark:text-gray-100"><%= Number(o.finalPrice || o.totalPrice || 0).toLocaleString('fa-IR') %> تومان</span>
                <a href="/dashboard/orders/<%= o._id %>" class="bg-blue-500 hover:bg-blue-600 text-white rounded-lg px-4 py-1.5 text-xs">جزئیات</a>
              </div>
            </div>
          </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</main>
