<style>
    button {
        padding: 0.625rem 1.5rem !important;
    }
</style>

<main class="container relative">
    <div class="flex flex-col lg:flex-row gap-x-8 mt-10">
        <!-- SIDE MENU -->
        <div class="lg:sticky mb-8 top-1 h-fit lg:w-1/4 hidden lg:flex flex-col gap-y-4 items-center shadow rounded-lg p-4 dark:bg-gray-800 bg-white">
             <!-- NAME AND AVATAR  -->
             <div class="w-full flex items-center justify-between border-b border-gray-200 dark:border-white/20 py-3">
                <div class="flex items-center gap-x-3">
                    <img src="/images/svg/user.png" class="size-10 ring-2 ring-gray-400/20 rounded-full"
                        alt="AVATAR">
                    <span class="felx flex-col gap-y-2">
                        <p class="font-DanaMedium text-lg">
                            <% if(user?.firstName && user?.lastName){ %>
                                <%= user?.firstName %><%= user?.lastName %>
                            <% }else{ %>
                                کاربر گرامی
                            <% } %>
                        </p>
                        <p class="text-gray-400"><%= user?.phone %></p>
                    </span>
                </div>
            </div> 
            <ul
                class="w-full relative space-y-2 child:duration-300 child:transition-all child:py-3  child:px-2 child:flex child:gap-x-2 text-lg child:cursor-pointer child:rounded-lg">
                <li <% if (req.path === '/') { %> class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard">
                    <svg class="w-6 h-6 ">
                        <use href="#squares"></use>
                    </svg>
                    </a>
                    <a href="/dashboard">داشبورد</a>
                </li>
                <li <% if (req.path === '/orders') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                <a href="/dashboard/orders">
                    <svg class="w-6 h-6 ">
                        <use href="#shopping-bag"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/orders">سفارش ها</a>
                </li>
                <li <% if (req.path === '/address') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard/address">
                    <svg class="w-6 h-6 ">
                        <use href="#map"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/address">آدرس ها</a>
                </li>
                <li <% if (req.path === '/mine') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/program/mine">
                    <svg class="w-6 h-6 ">
                        <use href="#document"></use>
                    </svg>
                    </a>
                    <a href="/program/mine">برنامه‌های من</a>
                </li>
                <li <% if (req.path === '/account') { %>class="bg-blue-500/10 text-blue-500" <%} else {%> class="hover:text-blue-500"<% } %>>
                    <a href="/dashboard/account">
                    <svg class="w-6 h-6 ">
                        <use href="#cog"></use>
                    </svg>
                    </a>
                    <a href="/dashboard/account">اطلاعات حساب </a>
                </li>
                <li class="text-red-400">
                    <a href="/logout">
                    <svg class="w-6 h-6 ">
                        <use href="#arrow-left-end"></use>
                    </svg>
                    </a>
                    <a href="/logout">خروج</a>
                </li>
            </ul>
        </div>
        <!-- TOP FILTER BOX & PRODUCT & PAGINATION -->
        <div class="lg:w-3/4">
            <div class="flex lg:hidden">
               <button class="mi-press open-user-menu bg-blue-500 flex items-center gap-x-1 font-DanaMedium text-white p-2 rounded-lg text-sm mr-2">
                    <svg class="size-5">
                        <use href="#bars-3" />
                    </svg>
                    منوی کاربری
                </button>
                <div class="user-menu">
                     <button class="close-user-menu">
                        <svg class="size-6">
                        <use href="#x-mark" />
                        </svg>
                     </button>
                     <!-- NAME AND AVATAR  -->
                    <div class="w-full flex items-center justify-between border-b border-gray-200 dark:border-white/20 py-3">
                <div class="flex items-center gap-x-3">
                    <img src="/images/svg/user.png" class="size-10 ring-2 ring-gray-400/20 rounded-full"
                        alt="AVATAR">
                    <span class="felx flex-col gap-y-2">
                        <p class="font-DanaMedium text-lg">
                            <% if(user?.firstName && user?.lastName){ %>
                                <%= user?.firstName %><%= user?.lastName %>
                            <% }else{ %>سبد خرید
                                کاربر گرامی
                            <% } %>
                        </p>
                        <p class="text-gray-400"><%= user?.phone %></p>
                    </span>
                </div>
                    </div> 
                    <ul
                    class="w-full relative space-y-2 child:duration-300 child:transition-all child:py-3  child:px-2 child:flex child:gap-x-2 text-lg child:cursor-pointer child:rounded-lg">
                    <li class="bg-blue-500/10 text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#squares"></use>
                        </svg>
                        <a href="/dashboard">داشبورد</a>
                    </li>
                    <li class="hover:text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#shopping-bag"></use>
                        </svg>
                        <a href="/dashboard/orders">سفارش ها</a>
                    </li>
                    <li class="hover:text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#map"></use>
                        </svg>
                        <a href="/dashboard/address">آدرس ها</a>
                    </li>
                    <li class="hover:text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#bell"></use>
                        </svg>
                        <a href="/dashboard">پیام ها</a>
                    </li>
                    <li class="hover:text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#document"></use>
                        </svg>
                        <a href="/program/mine">برنامه‌های من</a>
                    </li>
                    <li class="hover:text-blue-500">
                        <svg class="w-6 h-6 ">
                            <use href="#cog"></use>
                        </svg>
                        <a href="/dashboard">اطلاعات حساب </a>
                    </li>
                    <li class="text-red-400">
                        <svg class="w-6 h-6 ">
                            <use href="#arrow-left-end"></use>
                        </svg>
                        <a href="/logout">خروج</a>
                    </li>
                    </ul>
                </div>
            </div>

           <!-- اطلاعات حساب -->
           <div class="w-full flex flex-col shadow rounded-lg p-4 dark:bg-gray-800 bg-white mt-5">
                <span class="flex items-center gap-x-2">
                    <svg class="size-7 text-blue-500"><use href="#cog" /></svg>
                    <h2 class="font-DanaMedium text-lg">اطلاعات حساب</h2>
                </span>
                <form action="/dashboard/profile" method="POST" class="mt-5 grid grid-cols-12 gap-4">
                    <div class="col-span-12 md:col-span-6">
                        <label class="block text-sm font-DanaMedium text-gray-500 dark:text-gray-300 mb-2">نام</label>
                        <input name="firstName" type="text" value="<%= (typeof profile !== 'undefined' && profile.firstName) || '' %>" placeholder="نام"
                            class="block w-full p-2.5 text-sm text-gray-800 dark:text-gray-100 dark:bg-gray-900 bg-slate-100 border border-transparent rounded-md outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 dark:focus:ring-blue-400">
                    </div>
                    <div class="col-span-12 md:col-span-6">
                        <label class="block text-sm font-DanaMedium text-gray-500 dark:text-gray-300 mb-2">نام خانوادگی</label>
                        <input name="lastName" type="text" value="<%= (typeof profile !== 'undefined' && profile.lastName) || '' %>" placeholder="نام خانوادگی"
                            class="block w-full p-2.5 text-sm text-gray-800 dark:text-gray-100 dark:bg-gray-900 bg-slate-100 border border-transparent rounded-md outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 dark:focus:ring-blue-400">
                    </div>
                    <div class="col-span-12 md:col-span-6">
                        <label class="block text-sm font-DanaMedium text-gray-500 dark:text-gray-300 mb-2">ایمیل</label>
                        <input name="email" type="email" value="<%= (typeof profile !== 'undefined' && profile.email) || '' %>" placeholder="example@mail.com" dir="ltr"
                            class="block w-full p-2.5 text-sm text-gray-800 dark:text-gray-100 dark:bg-gray-900 bg-slate-100 border border-transparent rounded-md outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 dark:focus:ring-blue-400">
                    </div>
                    <div class="col-span-12 md:col-span-6">
                        <label class="block text-sm font-DanaMedium text-gray-500 dark:text-gray-300 mb-2">شماره موبایل</label>
                        <input type="text" value="<%= user?.phone %>" dir="ltr" readonly
                            class="block w-full p-2.5 text-sm text-gray-400 dark:bg-gray-900 bg-slate-100 border border-transparent rounded-md outline-none cursor-not-allowed">
                    </div>
                    <div class="col-span-12 flex justify-end">
                        <button type="submit" class="mi-press bg-blue-500 hover:bg-blue-600 text-white rounded-lg px-6 py-2.5 text-sm font-DanaMedium">ذخیره اطلاعات</button>
                    </div>
                </form>
           </div>
        </div>
    </div>
</main>



<!-- Overlay -->
<div class="overlay"></div>
<div class="search-overlay"></div>

<script src="/scripts/dashboard.js"></script>