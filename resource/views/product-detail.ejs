<div class="container" style="padding: 2rem 0;">
    <!-- Breadcrumb -->
    <nav style="margin-bottom: 2rem;">
        <ol style="display: flex; list-style: none; gap: 1rem; color: #666;">
            <li><a href="/" style="color: var(--primary-blue); text-decoration: none;">صفحه اصلی</a></li>
            <li>/</li>
            <li><a href="/products" style="color: var(--primary-blue); text-decoration: none;">محصولات</a></li>
            <li>/</li>
            <li><%= product.category %></li>
            <li>/</li>
            <li style="color: var(--dark-gray);"><%= product.name %></li>
        </ol>
    </nav>
    
    <!-- Product Detail -->
    <div class="card">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; padding: 2rem;">
            
            <!-- Product Images -->
            <div>
                <div style="position: relative;">
                    <% if (product.discountPercentage > 0) { %>
                        <div style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                            <span class="discount-badge" style="font-size: 1.2rem; padding: 0.5rem 1rem;">
                                %<%= product.discountPercentage %> تخفیف
                            </span>
                        </div>
                    <% } %>
                    <img id="mainImage" src="<%= product.images[0] || 'https://via.placeholder.com/500' %>" alt="<%= product.name %>" 
                         style="width: 100%; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.1);">
                </div>
                
                <!-- Thumbnail Images -->
                <% if (product.images.length > 1) { %>
                    <div style="display: flex; gap: 10px; margin-top: 1rem;">
                        <% product.images.forEach(image => { %>
                            <img src="<%= image %>" alt="Thumbnail" 
                                 onclick="changeImage('<%= image %>')"
                                 style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; cursor: pointer; border: 2px solid transparent; transition: border 0.3s;">
                        <% }); %>
                    </div>
                <% } %>
            </div>
            
            <!-- Product Info -->
            <div>
                <h1 style="color: var(--dark-gray); margin-bottom: 0.5rem;"><%= product.name %></h1>
                <p style="color: var(--accent-orange); font-size: 1.2rem; font-weight: 600; margin-bottom: 1rem;">
                    <%= product.brand %>
                </p>
                
                <!-- Rating -->
                <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                    <div>
                        <% for(let i = 1; i <= 5; i++) { %>
                            <i class="fas fa-star" style="color: <%= i <= product.ratings.average ? '#FFD700' : '#E0E0E0' %>;"></i>
                        <% } %>
                    </div>
                    <span style="color: #666;">
                        <%= product.ratings.average.toFixed(1) %> از 5
                        (<%= product.ratings.count %> نظر)
                    </span>
                    <a href="#reviews" style="color: var(--primary-blue); text-decoration: none;">مشاهده نظرات</a>
                </div>
                
                <!-- Price -->
                <div style="background: var(--light-blue); padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
                    <% if (product.discountPrice) { %>
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                            <span style="text-decoration: line-through; color: #999; font-size: 1.2rem;">
                                <%= product.price.toLocaleString('fa-IR') %> تومان
                            </span>
                            <span style="background: var(--accent-orange); color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.9rem;">
                                <%= Math.round(((product.price - product.discountPrice) / product.price) * 100) %>% تخفیف
                            </span>
                        </div>
                    <% } %>
                    <div style="font-size: 2rem; font-weight: bold; color: var(--primary-blue);">
                        <%= product.currentPrice.toLocaleString('fa-IR') %> تومان
                    </div>
                </div>
                
                <!-- Product Details -->
                <div style="margin-bottom: 2rem;">
                    <% if (product.weight) { %>
                        <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #E0E0E0;">
                            <span style="color: #666;">وزن:</span>
                            <strong><%= product.weight %></strong>
                        </div>
                    <% } %>
                    
                    <% if (product.servings) { %>
                        <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #E0E0E0;">
                            <span style="color: #666;">تعداد سروینگ:</span>
                            <strong><%= product.servings %> عدد</strong>
                        </div>
                    <% } %>
                    
                    <% if (product.flavor) { %>
                        <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #E0E0E0;">
                            <span style="color: #666;">طعم:</span>
                            <strong><%= product.flavor %></strong>
                        </div>
                    <% } %>
                    
                    <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid #E0E0E0;">
                        <span style="color: #666;">دسته‌بندی:</span>
                        <a href="/products?category=<%= product.category %>" style="color: var(--primary-blue); text-decoration: none;">
                            <%= product.category %>
                        </a>
                    </div>
                    
                    <div style="display: flex; justify-content: space-between; padding: 0.75rem 0;">
                        <span style="color: #666;">وضعیت:</span>
                        <% if (product.stock > 0) { %>
                            <span style="color: var(--success); font-weight: 600;">
                                <i class="fas fa-check-circle"></i>
                                موجود در انبار (<%= product.stock %> عدد)
                            </span>
                        <% } else { %>
                            <span style="color: var(--danger); font-weight: 600;">
                                <i class="fas fa-times-circle"></i>
                                ناموجود
                            </span>
                        <% } %>
                    </div>
                </div>
                
                <!-- Add to Cart -->
                <% if (product.stock > 0) { %>
                    <div style="display: flex; gap: 1rem; margin-bottom: 2rem;">
                        <div style="display: flex; align-items: center; border: 2px solid #E0E0E0; border-radius: 8px;">
                            <button onclick="decreaseQuantity()" style="padding: 0.75rem 1rem; background: none; border: none; cursor: pointer; font-size: 1.2rem;">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" id="quantity" value="1" min="1" max="<%= product.stock %>" 
                                   style="width: 60px; text-align: center; border: none; font-size: 1.1rem;">
                            <button onclick="increaseQuantity()" style="padding: 0.75rem 1rem; background: none; border: none; cursor: pointer; font-size: 1.2rem;">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        
                        <button onclick="addToCart('<%= product._id %>')" class="btn btn-accent" style="flex: 1; font-size: 1.1rem;">
                            <i class="fas fa-shopping-cart"></i>
                            افزودن به سبد خرید
                        </button>
                    </div>
                <% } else { %>
                    <button class="btn" disabled style="width: 100%; background: #ccc; cursor: not-allowed; font-size: 1.1rem;">
                        ناموجود
                    </button>
                <% } %>
                
                <!-- Actions -->
                <div style="display: flex; gap: 1rem;">
                    <button onclick="addToWishlist('<%= product._id %>')" class="btn btn-secondary" style="flex: 1;">
                        <i class="fas fa-heart"></i>
                        افزودن به علاقه‌مندی‌ها
                    </button>
                    <button onclick="shareProduct()" class="btn btn-secondary" style="flex: 1;">
                        <i class="fas fa-share-alt"></i>
                        اشتراک‌گذاری
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Product Tabs -->
    <div class="card" style="margin-top: 2rem;">
        <div style="display: flex; border-bottom: 2px solid #E0E0E0;">
            <button class="tab-btn active" onclick="showTab('description')">توضیحات</button>
            <button class="tab-btn" onclick="showTab('ingredients')">ترکیبات</button>
            <button class="tab-btn" onclick="showTab('usage')">نحوه مصرف</button>
            <button class="tab-btn" onclick="showTab('reviews')">نظرات (<%= product.reviews.length %>)</button>
        </div>
        
        <div style="padding: 2rem;">
            <!-- Description Tab -->
            <div id="description-tab" class="tab-content active">
                <h3 style="margin-bottom: 1rem;">توضیحات محصول</h3>
                <p style="line-height: 1.8; color: #666;">
                    <%= product.description %>
                </p>
            </div>
            
            <!-- Ingredients Tab -->
            <div id="ingredients-tab" class="tab-content" style="display: none;">
                <h3 style="margin-bottom: 1rem;">ترکیبات</h3>
                <p style="line-height: 1.8; color: #666;">
                    <%= product.ingredients %>
                </p>
            </div>
            
            <!-- Usage Tab -->
            <div id="usage-tab" class="tab-content" style="display: none;">
                <h3 style="margin-bottom: 1rem;">نحوه مصرف</h3>
                <p style="line-height: 1.8; color: #666;">
                    <%= product.usage %>
                </p>
            </div>
            
            <!-- Reviews Tab -->
            <div id="reviews-tab" class="tab-content" style="display: none;">
                <h3 style="margin-bottom: 2rem;">نظرات کاربران</h3>
                
                <!-- Add Review Form -->
                <% if (user) { %>
                    <div style="background: var(--light-gray); padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
                        <h4 style="margin-bottom: 1rem;">ثبت نظر جدید</h4>
                        <form action="/products/<%= product._id %>/review" method="POST">
                            <div class="form-group">
                                <label class="form-label">امتیاز شما:</label>
                                <div style="font-size: 1.5rem;">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <i class="fas fa-star rating-star" data-rating="<%= i %>" 
                                           style="color: #E0E0E0; cursor: pointer;"></i>
                                    <% } %>
                                </div>
                                <input type="hidden" name="rating" id="rating-input" required>
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">نظر شما:</label>
                                <textarea name="comment" class="form-control" rows="3" required></textarea>
                            </div>
                            
                            <button type="submit" class="btn btn-primary">ثبت نظر</button>
                        </form>
                    </div>
                <% } else { %>
                    <div style="background: var(--light-gray); padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem; text-align: center;">
                        <p>برای ثبت نظر باید <a href="/auth/login" style="color: var(--primary-blue);">وارد حساب کاربری</a> خود شوید</p>
                    </div>
                <% } %>
                
                <!-- Reviews List -->
                <% if (product.reviews.length > 0) { %>
                    <% product.reviews.forEach(review => { %>
                        <div style="border-bottom: 1px solid #E0E0E0; padding: 1.5rem 0;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <strong><%= review.user.firstName %> <%= review.user.lastName %></strong>
                                <span style="color: #666; font-size: 0.9rem;">
                                    <%= new Date(review.date).toLocaleDateString('fa-IR') %>
                                </span>
                            </div>
                            
                            <div style="margin-bottom: 0.5rem;">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="fas fa-star" style="color: <%= i <= review.rating ? '#FFD700' : '#E0E0E0' %>; font-size: 0.9rem;"></i>
                                <% } %>
                            </div>
                            
                            <p style="color: #666;"><%= review.comment %></p>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="text-align: center; color: #666; padding: 2rem;">هنوز نظری برای این محصول ثبت نشده است</p>
                <% } %>
            </div>
        </div>
    </div>
    
    <!-- Related Products -->
    <div style="margin-top: 3rem;">
        <h2 style="margin-bottom: 2rem;">محصولات مرتبط</h2>
        <div class="products-grid">
            <!-- Related products would be loaded here -->
        </div>
    </div>
</div>

<style>
.tab-btn {
    padding: 1rem 2rem;
    background: none;
    border: none;
    font-size: 1rem;
    font-weight: 600;
    color: #666;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
}

.tab-btn:hover {
    color: var(--primary-blue);
}

.tab-btn.active {
    color: var(--primary-blue);
}

.tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    right: 0;
    left: 0;
    height: 2px;
    background: var(--accent-orange);
}

.rating-star:hover,
.rating-star.active {
    color: #FFD700 !important;
}
</style>

<script>
function changeImage(src) {
    document.getElementById('mainImage').src = src;
}

function showTab(tabName) {
    // Hide all tabs
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.style.display = 'none';
    });
    
    // Remove active class from all buttons
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    
    // Show selected tab
    document.getElementById(`${tabName}-tab`).style.display = 'block';
    
    // Add active class to clicked button
    event.target.classList.add('active');
}

function increaseQuantity() {
    const input = document.getElementById('quantity');
    const max = parseInt(input.max);
    if (parseInt(input.value) < max) {
        input.value = parseInt(input.value) + 1;
    }
}

function decreaseQuantity() {
    const input = document.getElementById('quantity');
    if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
    }
}

function addToCart(productId) {
    const quantity = document.getElementById('quantity').value;
    
    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ 
            productId: productId,
            quantity: parseInt(quantity)
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification('محصول به سبد خرید اضافه شد', 'success');
            // Update cart count
            const cartCount = document.querySelector('.cart-count');
            if (cartCount) {
                cartCount.textContent = data.cartCount;
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('خطا در افزودن به سبد خرید', 'error');
    });
}

function addToWishlist(productId) {
    // Implement wishlist functionality
    showNotification('به علاقه‌مندی‌ها اضافه شد', 'success');
}

function shareProduct() {
    if (navigator.share) {
        navigator.share({
            title: '<%= product.name %>',
            text: '<%= product.description.substring(0, 100) %>',
            url: window.location.href
        });
    } else {
        // Copy link to clipboard
        navigator.clipboard.writeText(window.location.href);
        showNotification('لینک محصول کپی شد', 'success');
    }
}

// Rating stars interaction
document.querySelectorAll('.rating-star').forEach(star => {
    star.addEventListener('click', function() {
        const rating = this.dataset.rating;
        document.getElementById('rating-input').value = rating;
        
        // Update star colors
        document.querySelectorAll('.rating-star').forEach((s, index) => {
            if (index < rating) {
                s.classList.add('active');
            } else {
                s.classList.remove('active');
            }
        });
    });
});

function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} fade-in`;
    notification.style.position = 'fixed';
    notification.style.top = '80px';
    notification.style.left = '50%';
    notification.style.transform = 'translateX(-50%)';
    notification.style.zIndex = '9999';
    notification.innerHTML = `<i class="fas fa-${type === 'success' ? 'check' : 'times'}-circle"></i> ${message}`;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.style.opacity = '0';
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}
</script>
