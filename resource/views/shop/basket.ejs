<main class="container">
    <!-- Breadcrumb -->
    <nav class="flex mt-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
            <li class="inline-flex items-center">
                <a href="/" class="inline-flex items-center text-sm gap-x-1 text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
                    <svg class="size-4 mb-0.5"><use href="#home" /></svg>
                    صفحه اصلی
                </a>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                    </svg>
                    <span class="ms-1 text-sm text-gray-500 md:ms-2 dark:text-gray-400">سبد خرید</span>
                </div>
            </li>
        </ol>
    </nav>

    <%
        let validItems = (basket && basket.items)
            ? basket.items.filter(function (it) { return it.product; })
            : [];

        let itemsTotal = 0;
        validItems.forEach(function (it) {
            itemsTotal += (it.product.priceSingle || 0) * it.quantity;
        });
        let totalCount = validItems.reduce(function (sum, it) { return sum + it.quantity; }, 0);
        let discount = 0;
        let finalPrice = itemsTotal - discount;
    %>

    <% if (validItems.length === 0) { %>
        <!-- ===== حالت سبد خالی ===== -->
        <section class="flex flex-col items-center justify-center text-center bg-white dark:bg-gray-800 shadow rounded-lg p-10 mt-5 gap-y-4">
            <svg class="w-20 h-20 text-gray-300 dark:text-gray-600"><use href="#shopping-bag"></use></svg>
            <h2 class="font-DanaMedium text-xl">سبد خرید شما خالی است</h2>
            <p class="text-gray-400 text-sm">هنوز محصولی به سبد خرید اضافه نکرده‌اید.</p>
            <a href="/shop" class="mt-2 flex items-center gap-x-1 justify-center bg-blue-500 text-white hover:bg-blue-600 transition-all rounded-lg shadow py-2 px-6">
                مشاهده محصولات
                <svg class="w-5 h-5"><use href="#chevron-left"></use></svg>
            </a>
        </section>
    <% } else { %>
        <!-- ===== سبد خرید پر ===== -->
        <section class="flex flex-col lg:flex-row justify-between items-start gap-4 child:rounded-lg child:bg-white child:dark:bg-gray-800 child:shadow child:p-4 mt-5">

            <!-- products -->
            <div class="w-full lg:w-3/4 flex flex-col gap-y-8" id="basketItems">
                <!-- header -->
                <div class="flex items-center justify-between">
                    <span class="flex items-center gap-x-2">
                        <h2 class="font-DanaMedium text-xl">سبد خرید</h2>
                        <p class="text-gray-400">(<span id="totalCountLabel"><%= totalCount %></span> کالا)</p>
                    </span>
                    <span class="flex items-center gap-x-1 text-red-600 dark:text-white cursor-pointer" id="clearBasketBtn">
                        <p class="mt-1 font-DanaMedium">حذف همه</p>
                        <svg class="w-5 h-5"><use href="#trash"></use></svg>
                    </span>
                </div>

                <!-- PRODUCT ITEMS -->
                <div class="w-full flex flex-col gap-y-4 child:p-2 lg:child:p-4">
                    <% validItems.forEach(function (item, index) { %>
                        <% let p = item.product; %>
                        <% let unitPrice = p.priceSingle || 0; %>
                        <div class="cart-row w-full flex justify-between relative <%= index < validItems.length - 1 ? 'border-b-2 border-gray-200 dark:border-white/20' : '' %>"
                             data-product-id="<%= p._id %>"
                             data-unit-price="<%= unitPrice %>"
                             data-stock="<%= p.quantity %>"
                             data-original-qty="<%= item.quantity %>">
                            <div class="flex flex-col sm:flex-row items-center gap-6">
                                <div class="flex w-fit flex-col">
                                    <img src="<%= p.image %>" class="w-36" alt="<%= p.title %>">
                                    <button type="button" class="flex items-center justify-between gap-x-1 rounded-lg border border-gray-200 dark:border-white/20 py-1 px-2">
                                        <svg class="w-4 h-4 increment text-green-600 cursor-pointer"><use href="#plus"></use></svg>
                                        <input type="number" min="1" max="<%= p.quantity %>" value="<%= item.quantity %>"
                                            class="qty-input mr-3 text-lg bg-transparent w-12 text-center outline-none" readonly>
                                        <svg class="w-4 h-4 decrement text-red-500 cursor-pointer"><use href="#minus"></use></svg>
                                    </button>
                                </div>
                                <div class="flex flex-col gap-y-4">
                                    <h2 class="font-DanaMedium line-clamp-1"><%= p.title %></h2>
                                    <ul class="space-y-3 child:text-sm text-gray-400 child:flex child:items-center child:gap-x-1.5">
                                        <% if (p.flavor) { %><li><p>طعم: <%= p.flavor %></p></li><% } %>
                                        <% if (p.weight) { %><li><p>وزن: <%= p.weight %></p></li><% } %>
                                        <li>
                                            <svg class="w-5 h-5"><use href="#truck"></use></svg>
                                            <p class="mt-1">ارسال سریع</p>
                                        </li>
                                    </ul>
                                    <span class="flex items-center gap-x-1 text-gray-700 dark:text-gray-300 font-DanaMedium mt-4">
                                        <p class="font-DanaMedium text-xl row-total"><%= Number(unitPrice * item.quantity).toLocaleString('fa-IR') %></p>
                                        <p class="text-lg">تومان</p>
                                    </span>
                                    <svg class="flex sm:hidden absolute top-0 left-0 w-5 h-5 cursor-pointer remove-item" data-product-id="<%= p._id %>">
                                        <use href="#close"></use>
                                    </svg>
                                </div>
                            </div>
                            <div class="hidden sm:flex items-end justify-between flex-col">
                                <svg class="w-5 h-5 cursor-pointer remove-item" data-product-id="<%= p._id %>"><use href="#x-mark"></use></svg>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- PRICE BOX -->
            <div class="w-full lg:w-1/4 lg:sticky top-5 flex flex-col gap-y-4">
                <ul class="child:flex child:items-center child:justify-between space-y-8">
                    <li>
                        <p>قیمت کالاها (<span id="priceBoxCount"><%= totalCount %></span>)</p>
                        <p class="flex gap-x-1 text-gray-600 dark:text-gray-300">
                            <span id="itemsTotal"><%= Number(itemsTotal).toLocaleString('fa-IR') %></span>
                            <span class="hidden xl:flex">تومان</span>
                        </p>
                    </li>
                    <li>
                        <p>تخفیف</p>
                        <p class="font-DanaMedium text-gray-700 dark:text-gray-200">
                            <span id="discount"><%= Number(discount).toLocaleString('fa-IR') %></span> تومان
                        </p>
                    </li>
                    <li class="border-t-2 border-dashed border-gray-400 pt-4">
                        <p>مبلغ نهایی :</p>
                        <p><span id="finalPrice"><%= Number(finalPrice).toLocaleString('fa-IR') %></span> تومان</p>
                    </li>
                </ul>

                <!-- ===== انتخاب درگاه پرداخت ===== -->
                <div class="flex flex-col gap-y-2 pt-2 border-t-2 border-dashed border-gray-300 dark:border-gray-600">
                    <p class="font-DanaMedium text-sm">انتخاب درگاه پرداخت :</p>

                    <!-- زرین‌پال -->
                    <label class="gateway-option flex items-center justify-between gap-x-2 p-3 rounded-lg border-2 border-gray-200 dark:border-white/20 cursor-pointer transition-all has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 dark:has-[:checked]:bg-blue-900/10">
                        <span class="flex items-center gap-x-2">
                            <input type="radio" name="gateway" value="zarinpal" class="accent-blue-500" checked>
                            <span class="font-DanaMedium text-sm">درگاه زرین‌پال</span>
                        </span>
                        <span class="text-xs text-gray-400">پرداخت کامل</span>
                    </label>

                    <!-- دیجی‌پی -->
                    <label class="gateway-option flex items-center justify-between gap-x-2 p-3 rounded-lg border-2 border-gray-200 dark:border-white/20 cursor-pointer transition-all has-[:checked]:border-purple-500 has-[:checked]:bg-purple-50 dark:has-[:checked]:bg-purple-900/10">
                        <span class="flex items-center gap-x-2">
                            <input type="radio" name="gateway" value="digipay" class="accent-purple-500">
                            <span class="font-DanaMedium text-sm">دیجی‌پی</span>
                        </span>
                        <span class="text-xs text-purple-500 font-DanaMedium">۴ قسط</span>
                    </label>
                </div>

                <!-- دکمه بروزرسانی -->
                <button id="updateBasketBtn" type="button" style="background-color: orange" disabled
                    class="w-full flex items-center gap-x-1 justify-center text-white hover:opacity-90 transition-all rounded-lg shadow py-2 disabled:opacity-40 disabled:cursor-not-allowed">
                    بروزرسانی سبد
                </button>

                <!-- دکمه تکمیل سفارش -->
                <button id="checkoutBtn" type="button"
                    class="w-full flex items-center gap-x-1 justify-center bg-blue-500 text-white hover:bg-blue-600 transition-all rounded-lg shadow py-2">
                    تایید و پرداخت
                    <svg class="w-5 h-5"><use href="#shopping-bag"></use></svg>
                </button>
            </div>
        </section>
    <% } %>
</main>

<script>
    (function () {
        const itemsContainer = document.getElementById("basketItems");
        if (!itemsContainer) return;

        // Toast برای پیام‌های زودگذر (بدون دکمه)
        const Toast = window.Swal ? Swal.mixin({
            toast: true,
            position: "top-end",
            showConfirmButton: false,
            timer: 2200,
            timerProgressBar: true,
        }) : null;

        // پیام کمکی: اگر Swal بود Toast، وگرنه alert
        function notify(title, icon) {
            if (Toast) Toast.fire({ title: title, icon: icon || "info" });
            else alert(title);
        }

        const updateBtn   = document.getElementById("updateBasketBtn");
        const clearBtn    = document.getElementById("clearBasketBtn");
        const checkoutBtn = document.getElementById("checkoutBtn");
        const itemsTotalEl = document.getElementById("itemsTotal");
        const finalPriceEl = document.getElementById("finalPrice");
        const totalCountLabel = document.getElementById("totalCountLabel");
        const priceBoxCount = document.getElementById("priceBoxCount");

        const faFmt = (n) => Number(n || 0).toLocaleString("fa-IR");

        function isDirty() {
            return [...document.querySelectorAll(".cart-row")].some(function (row) {
                return Number(row.querySelector(".qty-input").value) !== Number(row.dataset.originalQty);
            });
        }

        function recalc() {
            let total = 0, count = 0;
            document.querySelectorAll(".cart-row").forEach(function (row) {
                const qty = Number(row.querySelector(".qty-input").value) || 0;
                const unit = Number(row.dataset.unitPrice) || 0;
                row.querySelector(".row-total").textContent = faFmt(unit * qty);
                total += unit * qty;
                count += qty;
            });
            itemsTotalEl.textContent = faFmt(total);
            finalPriceEl.textContent = faFmt(total);
            if (totalCountLabel) totalCountLabel.textContent = faFmt(count);
            if (priceBoxCount) priceBoxCount.textContent = faFmt(count);
            updateBtn.disabled = !isDirty();
        }

        // افزایش / کاهش (محلی)
        itemsContainer.addEventListener("click", function (e) {
            const incBtn = e.target.closest(".increment");
            const decBtn = e.target.closest(".decrement");
            if (!incBtn && !decBtn) return;
            const row = e.target.closest(".cart-row");
            const input = row.querySelector(".qty-input");
            const stock = Number(row.dataset.stock);
            let q = Number(input.value);
            if (incBtn) {
                if (q + 1 > stock) {
                    notify("بیش از موجودی انبار نیست", "warning");
                    return;
                }
                q++;
            } else {
                if (q - 1 < 1) return;
                q--;
            }
            input.value = q;
            recalc();
        });

        // حذف یک آیتم
        itemsContainer.addEventListener("click", async function (e) {
            const rm = e.target.closest(".remove-item");
            if (!rm) return;
            try {
                const res = await fetch("/basket/remove/" + rm.dataset.productId, { method: "DELETE" });
                if (res.redirected) { window.location.href = res.url; return; }
                const data = await res.json();
                if (data && data.success) {
                    if (typeof window.updateCartCount === "function") window.updateCartCount(data.totalItems);
                    location.reload();
                } else {
                    notify((data && data.message) || "خطا", "error");
                }
            } catch (_) { notify("خطا در ارتباط با سرور", "error"); }
        });

        // حذف همه
        if (clearBtn) {
            clearBtn.addEventListener("click", async function () {
                // تأیید: اینجا Swal معمولی (نه Toast) چون به دکمه نیاز داریم
                let ok;
                if (window.Swal) {
                    const result = await Swal.fire({
                        title: "همه‌ی محصولات حذف شوند؟",
                        icon: "warning",
                        showCancelButton: true,
                        confirmButtonText: "بله",
                        cancelButtonText: "خیر",
                    });
                    ok = result.isConfirmed;
                } else {
                    ok = confirm("همه‌ی محصولات حذف شوند؟");
                }
                if (!ok) return;

                try {
                    const res = await fetch("/basket/clear", { method: "DELETE" });
                    if (res.redirected) { window.location.href = res.url; return; }
                    const data = await res.json();
                    if (data && data.success) {
                        if (typeof window.updateCartCount === "function") window.updateCartCount(0);
                        location.reload();
                    }
                } catch (_) { notify("خطا در ارتباط با سرور", "error"); }
            });
        }

        // بروزرسانی سبد (دسته‌ای)
        updateBtn.addEventListener("click", async function () {
            const items = [...document.querySelectorAll(".cart-row")].map(function (row) {
                return { productId: row.dataset.productId, quantity: Number(row.querySelector(".qty-input").value) };
            });
            updateBtn.disabled = true;
            try {
                const res = await fetch("/basket/update", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ items }),
                });
                if (res.redirected) { window.location.href = res.url; return; }
                const data = await res.json();
                if (data && data.success) {
                    if (typeof window.updateCartCount === "function") window.updateCartCount(data.totalItems);
                    notify("سبد خرید بروزرسانی شد", "success");
                    document.querySelectorAll(".cart-row").forEach(function (row) {
                        row.dataset.originalQty = row.querySelector(".qty-input").value;
                    });
                    recalc();
                } else {
                    notify((data && data.message) || "خطا", "error");
                    updateBtn.disabled = false;
                }
            } catch (_) {
                notify("خطا در ارتباط با سرور", "error");
                updateBtn.disabled = false;
            }
        });

        // تکمیل سفارش و رفتن به درگاه
        checkoutBtn.addEventListener("click", async function () {
            if (isDirty()) {
                notify("اول سبد را بروزرسانی کنید", "info");
                return;
            }

            const gateway = document.querySelector('input[name="gateway"]:checked');
            const gatewayValue = gateway ? gateway.value : "zarinpal";

            checkoutBtn.disabled = true;
            try {
                const res = await fetch("/payment/create", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ gateway: gatewayValue }),
                });
                if (res.redirected) { window.location.href = res.url; return; }
                const data = await res.json();
                if (data && data.success && data.paymentUrl) {
                    window.location.href = data.paymentUrl;
                } else {
                    notify((data && data.message) || "خطا در اتصال به درگاه", "error");
                    checkoutBtn.disabled = false;
                }
            } catch (_) {
                notify("خطا در ارتباط با سرور", "error");
                checkoutBtn.disabled = false;
            }
        });
    })();
</script>
