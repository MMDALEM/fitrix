<!-- در این صفحه چت کامل هست؛ دکمه شناور لازم نیست -->
<style>.fx-consult-fab, .fx-consult-panel { display: none !important; }</style>

<main class="container mt-8 mb-16">
    <!-- Breadcrumb -->
    <nav class="flex mb-6" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
            <li class="inline-flex items-center">
                <a href="/" class="inline-flex items-center text-sm gap-x-1 text-gray-700 hover:text-blue-600 dark:text-gray-400">
                    <svg class="size-4 mb-0.5"><use href="#home" /></svg>
                    صفحه اصلی
                </a>
            </li>
            <li>
                <div class="flex items-center">
                    <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                    </svg>
                    <span class="ms-1 text-sm text-blue-500 md:ms-2">مشاوره رایگان</span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-2xl md:text-3xl font-MorabbaMedium text-gray-800 dark:text-gray-50">
                مشاوره <span class="text-blue-600 dark:text-blue-500">رایگان</span> مکمل با هوش مصنوعی
            </h1>
            <p class="text-sm text-gray-500 dark:text-gray-300 mt-3 leading-7">
                نمی‌دانید چه مکملی برای هدف شما مناسب است؟ از مشاور هوشمند فیت‌ریکس بپرسید؛
                بر اساس هدف، سطح تمرین و شرایط‌تان راهنمایی‌تان می‌کند و از بین محصولات موجود پیشنهاد می‌دهد.
            </p>
            <p class="text-xs text-amber-600 dark:text-amber-400 mt-2">
                ⚠️ پاسخ‌ها جنبه‌ی عمومی دارند و جایگزین مشاوره‌ی پزشک یا متخصص تغذیه نیستند.
            </p>
        </div>

        <!-- Chat box -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden flex flex-col" style="min-height: 420px;">
            <div id="chatMessages" class="flex-1 p-4 md:p-6 space-y-4 overflow-y-auto" style="max-height: 55vh;">
                <div class="flex justify-start">
                    <div class="max-w-[85%] rounded-2xl rounded-tr-sm bg-blue-50 dark:bg-gray-700 text-gray-800 dark:text-gray-100 px-4 py-3 text-sm leading-7">
                        سلام! 👋 من مشاور فیت‌ریکسم 😊
                        بگو هدفت چیه — عضله‌سازی، کاهش وزن، انرژی بیشتر یا ریکاوری — تا بهترین مکمل رو برات پیدا کنم 💪
                    </div>
                </div>
            </div>

            <!-- Clear -->
            <div class="px-4 pt-2 flex justify-end">
                <button id="chatReset" type="button" class="text-xs py-1 px-3 rounded-full text-red-500 hover:bg-red-50 dark:hover:bg-gray-700 transition-all">🗑 پاک کردن گفتگو</button>
            </div>

            <!-- Suggestions -->
            <div id="chatSuggestions" class="px-4 pb-2 flex flex-wrap gap-2">
                <button class="consult-suggest text-xs py-1.5 px-3 rounded-full bg-blue-50 dark:bg-gray-700 text-blue-600 dark:text-blue-300 hover:bg-blue-100 transition-all">برای عضله‌سازی چی بخرم؟</button>
                <button class="consult-suggest text-xs py-1.5 px-3 rounded-full bg-blue-50 dark:bg-gray-700 text-blue-600 dark:text-blue-300 hover:bg-blue-100 transition-all">پروتئین وی بهتره یا گینر؟</button>
                <button class="consult-suggest text-xs py-1.5 px-3 rounded-full bg-blue-50 dark:bg-gray-700 text-blue-600 dark:text-blue-300 hover:bg-blue-100 transition-all">کراتین چطور مصرف می‌شه؟</button>
                <button class="consult-suggest text-xs py-1.5 px-3 rounded-full bg-blue-50 dark:bg-gray-700 text-blue-600 dark:text-blue-300 hover:bg-blue-100 transition-all">تازه‌کارم، از کجا شروع کنم؟</button>
            </div>

            <!-- Input -->
            <form id="chatForm" class="border-t border-gray-100 dark:border-gray-700 p-3 md:p-4 flex items-center gap-x-2">
                <input id="chatInput" type="text" maxlength="2000" autocomplete="off"
                    placeholder="سوال خود را بنویسید..."
                    class="flex-1 bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-gray-100 rounded-xl px-4 py-3 text-sm outline-none ring-1 ring-gray-200 dark:ring-gray-600 focus:ring-blue-400 transition-all" />
                <button id="chatSend" type="submit"
                    class="flex-center gap-x-1 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-all text-white rounded-xl px-5 py-3 text-sm">
                    ارسال
                </button>
            </form>
        </div>
    </div>
</main>

<script>
(function () {
    var box = document.getElementById("chatMessages");
    var form = document.getElementById("chatForm");
    var input = document.getElementById("chatInput");
    var sendBtn = document.getElementById("chatSend");
    var suggestWrap = document.getElementById("chatSuggestions");
    var history = []; // {role, content}
    var busy = false;

    function esc(t) {
        var d = document.createElement("div");
        d.textContent = t;
        return d.innerHTML;
    }

    // لینک‌های /product/... داخل پاسخ کلیک‌پذیر می‌شوند
    function linkify(html) {
        // آدرس مطلق محصول → نسبی (تا الگوهای پایین بگیرندش)
        html = html.replace(/https?:\/\/[^\s<>()\]"']*\/product\//g, "/product/");
        // [نام محصول](/product/slug) → لینک با نام محصول (اسلاگ فارسی هم پشتیبانی می‌شود)
        html = html.replace(/\[([^\]]{1,100})\]\((\/product\/[\w\-.%\u0600-\u06FF]+)\)/g,
            '<a href="$2" class="text-blue-500 underline">$1</a>');
        // مسیر خام /product/slug → لینک (بدون دست زدن به href های ساخته‌شده)
        html = html.replace(/(^|[^"'>\]])(\/product\/[\w\-.%\u0600-\u06FF]+)/g,
            '$1<a href="$2" class="text-blue-500 underline">$2</a>');
        // **متن** مارک‌داون → پررنگ (ستاره‌ی خام نمایش داده نشود)
        html = html.replace(/\*\*([^*\n]{1,120})\*\*/g, "<strong>$1</strong>");
        return html;
    }

    function addMsg(role, text) {
        var wrap = document.createElement("div");
        wrap.className = role === "user" ? "flex justify-end" : "flex justify-start";
        var bubble = document.createElement("div");
        bubble.className = role === "user"
            ? "max-w-[85%] rounded-2xl rounded-tl-sm bg-blue-600 text-white px-4 py-3 text-sm leading-7"
            : "max-w-[85%] rounded-2xl rounded-tr-sm bg-blue-50 dark:bg-gray-700 text-gray-800 dark:text-gray-100 px-4 py-3 text-sm leading-7";
        bubble.innerHTML = linkify(esc(text)).replace(/\n/g, "<br>");
        wrap.appendChild(bubble);
        box.appendChild(wrap);
        box.scrollTop = box.scrollHeight;
        return bubble;
    }

    function setBusy(b) {
        busy = b;
        sendBtn.disabled = b;
        input.disabled = b;
    }

    async function send(text) {
        if (busy || !text.trim()) return;
        text = text.trim();
        if (suggestWrap) suggestWrap.style.display = "none";

        addMsg("user", text);
        history.push({ role: "user", content: text });
        input.value = "";
        setBusy(true);

        var typing = addMsg("assistant", "در حال فکر کردن...");
        typing.classList.add("animate-pulse");

        try {
            var r = await fetch("/consult/ask", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ messages: history.slice(-10) }),
            });
            var data = await r.json();
            typing.classList.remove("animate-pulse");
            if (data.success) {
                typing.innerHTML = linkify(esc(data.reply)).replace(/\n/g, "<br>");
                history.push({ role: "assistant", content: data.reply });
            } else {
                typing.innerHTML = esc(data.message || "خطایی رخ داد؛ دوباره تلاش کنید.");
                typing.classList.add("text-red-500");
                history.pop();
            }
        } catch (e) {
            typing.classList.remove("animate-pulse");
            typing.textContent = "ارتباط برقرار نشد؛ اینترنت خود را بررسی کنید.";
            typing.classList.add("text-red-500");
            history.pop();
        }
        box.scrollTop = box.scrollHeight;
        setBusy(false);
        input.focus();
    }

    form.addEventListener("submit", function (e) {
        e.preventDefault();
        send(input.value);
    });

    document.querySelectorAll(".consult-suggest").forEach(function (btn) {
        btn.addEventListener("click", function () { send(btn.textContent); });
    });

    var initialChat = box.innerHTML; // پیام خوش‌آمد اولیه
    var resetBtn = document.getElementById("chatReset");
    if (resetBtn) {
        resetBtn.addEventListener("click", function () {
            history = [];
            box.innerHTML = initialChat;
            if (suggestWrap) suggestWrap.style.display = "";
            input.focus();
        });
    }
})();
</script>
