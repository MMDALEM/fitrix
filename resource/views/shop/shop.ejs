

<main class="container">
<!-- Breadcrumb -->
<nav class="flex mt-8" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
        <li class="inline-flex items-center">
            <a href="/" class="inline-flex items-center text-sm gap-x-1 text-gray-700 hover:text-blue-600 dark:text-gray-400">
                <svg class="size-4 mb-0.5"><use href="#home" /></svg>
                صفحه اصلی
            </a>
        </li>
        <li>
            <div class="flex items-center">
                <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                </svg>
                <a href="/shop" class="ms-1 text-sm text-gray-500 md:ms-2 dark:text-gray-400">فروشگاه</a>
            </div>
        </li>
        <% if (currentFilters.selectedCategory) { %>
        <li>
            <div class="flex items-center">
                <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                </svg>
                <span class="ms-1 text-sm text-blue-500 md:ms-2"><%= currentFilters.selectedCategory.title %></span>
            </div>
        </li>
        <% } %>
        <% if (currentFilters.selectedBrand) { %>
        <li>
            <div class="flex items-center">
                <svg class="rtl:rotate-180 w-3 h-3 text-gray-400 mx-1" fill="none" viewBox="0 0 6 10">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4" />
                </svg>
                <span class="ms-1 text-sm text-purple-500 md:ms-2"><%= currentFilters.selectedBrand.title %></span>
            </div>
        </li>
        <% } %>
    </ol>
</nav>
    <% if (currentFilters.search) { %>
    <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
        <p class="text-gray-700 dark:text-gray-300">
            نتایج جستجو برای "<span class="font-DanaMedium text-blue-500"><%= currentFilters.search %></span>" 
            (<%= products.totalDocs %> محصول)
        </p>
    </div>
    <% } %>

    <div class="flex flex-col lg:flex-row gap-4 mt-5">
        <!-- SIDE FILTER BOX -->
        <div class="lg:sticky top-1 h-fit lg:w-1/4 hidden lg:flex flex-col gap-y-4 items-center shadow rounded-lg py-4 dark:bg-gray-800 bg-white">
            <!-- TITLE -->
            <div class="flex items-center justify-between w-full px-2 xl:px-4">
                <span class="flex items-center gap-x-1">
                    <p class="font-DanaMedium text-gray-700 dark:text-gray-200 text-lg">فیلترها</p>
                </span>
                <p class="text-blue-500 dark:text-blue-400 text-sm cursor-pointer" onclick="clearFilters()">
                    حذف فیلتر‌ها
                </p>
            </div>

            <!-- FILTERS -->
            <div class="w-full divide-y divide-slate-200 dark:divide-gray-700/20">
                
                <!-- فیلتر دسته‌بندی -->
                <div>
                    <button onclick="toggleAccordion(1)"
                        class="w-full flex justify-between items-center px-2 xl:px-4 pt-4 mb-4 text-gray-800 dark:text-gray-100">
                        <span>دسته بندی</span>
                        <span id="icon-1" class="text-gray-800 dark:text-gray-100">
                            <svg class="size-4 transition-transform duration-300">
                                <use href="#chevron-left"></use>
                            </svg>
                        </span>
                    </button>
                    <div id="content-1" class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
                        <div class="pb-3 text-gray-700 dark:text-gray-300 w-full flex flex-col gap-y-1.5">
                            <% categories.forEach((cat) => { %>
                            <div class="inline-flex items-center mr-2.5 mt-1">
                                <label class="relative flex cursor-pointer items-center rounded-full p-3"
                                    for="cat-<%= cat._id %>" data-ripple-dark="true">
                                    <input id="cat-<%= cat._id %>" type="radio" name="category" value="<%= cat.slug %>"
                                        <%= currentFilters.category === cat.slug ? 'checked' : '' %>
                                        onchange="applyFilter()"
                                        class="peer relative h-5 w-5 cursor-pointer appearance-none rounded border border-slate-300 shadow hover:shadow-md transition-all before:absolute before:top-2/4 before:left-2/4 before:block before:h-12 before:w-12 before:-translate-y-2/4 before:-translate-x-2/4 before:rounded-full before:bg-slate-400 before:opacity-0 before:transition-opacity checked:border-blue-500 checked:bg-blue-500 checked:before:bg-slate-400 hover:before:opacity-10 dark:bg-gray-600 dark:checked:bg-blue-500" />
                                    <span class="pointer-events-none absolute top-2/4 left-2/4 -translate-y-2/4 -translate-x-2/4 text-white opacity-0 transition-opacity peer-checked:opacity-100">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" stroke="currentColor" stroke-width="1">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                        </svg>
                                    </span>
                                </label>
                                <label class="cursor-pointer text-gray-800 dark:text-gray-400 mr-1" for="cat-<%= cat._id %>">
                                    <%= cat.title %>
                                </label>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <!-- فیلتر برند -->
                <div>
                    <button onclick="toggleAccordion(2)"
                        class="w-full flex justify-between items-center px-2 xl:px-4 py-4 text-gray-800 dark:text-gray-100">
                        <span>برند</span>
                        <span id="icon-2" class="text-gray-800 dark:text-gray-100">
                            <svg class="size-4 transition-transform duration-300">
                                <use href="#chevron-left"></use>
                            </svg>
                        </span>
                    </button>
                    <div id="content-2" class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
                        <div class="pb-3 text-gray-700 dark:text-gray-300 w-full flex flex-col gap-y-1.5">
                            <% brands.forEach((br) => { %>
                            <div class="inline-flex items-center mr-2.5 mt-1">
                                <label class="relative flex cursor-pointer items-center rounded-full p-3"
                                    for="brand-<%= br._id %>" data-ripple-dark="true">
                                    <input id="brand-<%= br._id %>" type="radio" name="brand" value="<%= br.slug %>"
                                        <%= currentFilters.brand === br.slug ? 'checked' : '' %>
                                        onchange="applyFilter()"
                                        class="peer relative h-5 w-5 cursor-pointer appearance-none rounded border border-slate-300 shadow hover:shadow-md transition-all before:absolute before:top-2/4 before:left-2/4 before:block before:h-12 before:w-12 before:-translate-y-2/4 before:-translate-x-2/4 before:rounded-full before:bg-slate-400 before:opacity-0 before:transition-opacity checked:border-blue-500 checked:bg-blue-500 checked:before:bg-slate-400 hover:before:opacity-10 dark:bg-gray-600 dark:checked:bg-blue-500" />
                                    <span class="pointer-events-none absolute top-2/4 left-2/4 -translate-y-2/4 -translate-x-2/4 text-white opacity-0 transition-opacity peer-checked:opacity-100">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" stroke="currentColor" stroke-width="1">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                        </svg>
                                    </span>
                                </label>
                                <label class="cursor-pointer text-gray-800 dark:text-gray-400 mr-1" for="brand-<%= br._id %>">
                                    <%= br.title %>
                                </label>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <!-- فیلتر موجودی -->
                <div class="w-full justify-between flex items-center gap-x-3 px-2 xl:px-4 py-4" dir="ltr">
                    <label for="inStock-switch" class="relative inline-block w-11 h-6 cursor-pointer">
                        <input type="checkbox" id="inStock-switch" class="peer sr-only"
                            <%= currentFilters.inStock === 'true' ? 'checked' : '' %>
                            onchange="applyFilter()">
                        <span class="absolute inset-0 bg-gray-200 rounded-full transition-colors duration-200 ease-in-out peer-checked:bg-blue-500 dark:bg-neutral-700 dark:peer-checked:bg-blue-500"></span>
                        <span class="absolute top-1/2 start-0.5 -translate-y-1/2 size-5 bg-white rounded-full shadow-xs transition-transform duration-200 ease-in-out peer-checked:translate-x-full dark:bg-neutral-400 dark:peer-checked:bg-white"></span>
                    </label>
                    <label for="inStock-switch" class="text-gray-800 dark:text-gray-100">
                        فقط کالاهای موجود
                    </label>
                </div>

                <!-- فیلتر محدوده قیمت -->
                <div>
                    <button onclick="toggleAccordion(3)"
                        class="w-full flex justify-between items-center px-2 xl:px-4 py-4 text-gray-800 dark:text-gray-100">
                        <span>محدوده قیمت</span>
                        <span id="icon-3" class="text-gray-800 dark:text-gray-100">
                            <svg class="size-4 transition-transform duration-300">
                                <use href="#chevron-left"></use>
                            </svg>
                        </span>
                    </button>
                    <div id="content-3" class="price-slider max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
                        <div class="pb-3 text-gray-700 dark:text-gray-300 w-full px-4">
                            <div class="flex flex-col gap-3 mt-3">
                                <div class="flex items-center gap-2">
                                    <label class="text-sm">از:</label>
                                    <input type="number" id="minPrice" value="<%= currentFilters.minPrice %>"
                                        placeholder="0"
                                        class="w-full px-3 py-2 rounded border dark:bg-gray-700 dark:border-gray-600">
                                    <span class="text-sm">تومان</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <label class="text-sm">تا:</label>
                                    <input type="number" id="maxPrice" value="<%= currentFilters.maxPrice %>"
                                        placeholder="100,000,000"
                                        class="w-full px-3 py-2 rounded border dark:bg-gray-700 dark:border-gray-600">
                                    <span class="text-sm">تومان</span>
                                </div>
                                <button onclick="applyFilter()"
                                    class="w-full py-2 bg-blue-500 text-white rounded hover:bg-blue-600 transition">
                                    اعمال فیلتر قیمت
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <!-- محصولات و صفحه‌بندی -->
        <div class="lg:w-3/4">
            
            <!-- فیلترهای موبایل -->
            <div class="flex lg:hidden items-center gap-x-2 flex-wrap">
                <button class="sort-modal-open text-sm mb-4 py-1.5 px-3 app-border rounded-full flex items-center gap-x-1">
                    <svg class="size-4 text-gray-400">
                        <use href="#sort-list"></use>
                    </svg>
                    <p>
                        <% if (currentFilters.sort === 'popular') { %>محبوب‌ترین
                        <% } else if (currentFilters.sort === 'bestselling') { %>پرفروش‌ترین
                        <% } else if (currentFilters.sort === 'cheapest') { %>ارزان‌ترین
                        <% } else if (currentFilters.sort === 'expensive') { %>گران‌ترین
                        <% } else { %>جدیدترین<% } %>
                    </p>
                </button>

                <button class="filter-modal-open text-sm mb-4 py-1.5 px-3 app-border rounded-full flex items-center gap-x-1">
                    <svg class="size-4 text-gray-400">
                        <use href="#filter"></use>
                    </svg>
                    <p>فیلتر</p>
                </button>

                <span class="text-sm text-gray-400 ms-auto py-1.5 px-4"><%= products.totalDocs %> کالا</span>
            </div>

            <!-- مرتب‌سازی دسکتاپ -->
            <div class="hidden lg:flex items-center justify-between mb-6">
                <div class="flex items-center gap-x-5">
                    <div class="flex items-center gap-x-2">
                        <svg class="size-6 text-gray-400">
                            <use href="#sort-list"></use>
                        </svg>
                        <h2 class="font-DanaDemiBold text-gray-400">مرتب سازی:</h2>
                    </div>
                    <ul class="flex items-center gap-x-1 lg:gap-x-4 child:transition-all child:cursor-pointer child:rounded-lg child:px-2 child:py-1 child:text-sm child:lg:text-base">
                        <li onclick="setSort('newest')" class="<%= currentFilters.sort === 'newest' ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'text-gray-400 hover:text-gray-600' %>">جدیدترین</li>
                        <li onclick="setSort('popular')" class="<%= currentFilters.sort === 'popular' ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'text-gray-400 hover:text-gray-600' %>">محبوب‌ترین</li>
                        <li onclick="setSort('bestselling')" class="<%= currentFilters.sort === 'bestselling' ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'text-gray-400 hover:text-gray-600' %>">پرفروش‌ترین</li>
                        <li onclick="setSort('cheapest')" class="<%= currentFilters.sort === 'cheapest' ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'text-gray-400 hover:text-gray-600' %>">ارزان‌ترین</li>
                        <li onclick="setSort('expensive')" class="<%= currentFilters.sort === 'expensive' ? 'text-blue-500 bg-blue-50 dark:bg-blue-900/20' : 'text-gray-400 hover:text-gray-600' %>">گران‌ترین</li>
                    </ul>
                </div>
                <span class="text-sm text-gray-400"><%= products.totalDocs %> کالا</span>
            </div>

            <!-- فیلترهای فعال -->
            <% if (currentFilters.category || currentFilters.brand || currentFilters.search || currentFilters.minPrice || currentFilters.maxPrice || currentFilters.inStock) { %>
            <div class="flex flex-wrap gap-2 mb-4">
                <% if (currentFilters.search) { %>
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full text-sm">
                    جستجو: <%= currentFilters.search %>
                    <button onclick="removeFilter('search')" class="hover:text-red-500">×</button>
                </span>
                <% } %>
                <% if (currentFilters.category) { 
                    const selectedCat = categories.find(c => c._id.toString() === currentFilters.category);
                %>
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 rounded-full text-sm">
                    دسته: <%= selectedCat ? selectedCat.title : '' %>
                    <button onclick="removeFilter('category')" class="hover:text-red-500">×</button>
                </span>
                <% } %>
                <% if (currentFilters.brand) { 
                    const selectedBrand = brands.find(b => b._id.toString() === currentFilters.brand);
                %>
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-full text-sm">
                    برند: <%= selectedBrand ? selectedBrand.title : '' %>
                    <button onclick="removeFilter('brand')" class="hover:text-red-500">×</button>
                </span>
                <% } %>
                <% if (currentFilters.minPrice || currentFilters.maxPrice) { %>
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 rounded-full text-sm">
                    قیمت: <%= currentFilters.minPrice || '0' %> - <%= currentFilters.maxPrice || '∞' %> تومان
                    <button onclick="removeFilter('price')" class="hover:text-red-500">×</button>
                </span>
                <% } %>
                <% if (currentFilters.inStock === 'true') { %>
                <span class="inline-flex items-center gap-1 px-3 py-1 bg-teal-100 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400 rounded-full text-sm">
                    فقط موجود
                    <button onclick="removeFilter('inStock')" class="hover:text-red-500">×</button>
                </span>
                <% } %>
            </div>
            <% } %>

            <!-- محصولات -->
            <% if (products.docs.length > 0) { %>
            <div class="grid grid-cols-1 xxs:grid-cols-2 xs:grid-cols-2 sm:grid-cols-2 xl:grid-cols-3 gap-3 xs:gap-2 sm:gap-4">
                <% products.docs.forEach((product) => { %>
                <div class="product-card group">
                    <div class="product-card_header">
                        <div class="flex items-center gap-x-2">
                            <div class="tooltip">
                                <button class="rounded-full p-1.5 app-border app-hover">
                                    <svg class="size-4">
                                        <use href="#shopping-cart"></use>
                                    </svg>
                                </button>
                                <div class="tooltiptext">سبد خرید</div>
                            </div>
                            <div class="tooltip">
                                <button class="rounded-full p-1.5 app-border app-hover">
                                    <svg class="size-4">
                                        <use href="#heart"></use>
                                    </svg>
                                </button>
                                <div class="tooltiptext">علاقه‌مندی</div>
                            </div>
                        </div>
                        <% if (product.originalPrice && product.originalPrice > product.priceSingle) { %>
                        <span class="product-card_badge">
                            <%= Math.round((1 - product.priceSingle / product.originalPrice) * 100) %>% تخفیف
                        </span>
                        <% } %>
                    </div>

                    <a href="/product/<%= product.slug %>" class="object-contain object-center h-full w-32 mx-auto transition-transform duration-300 group-hover:scale-105">
                        <img style="object-fit: scale-down;" class="product-card_img" 
                            src="<%= product.image %>"
                            alt="<%= product.title %>">
                    </a>

                    <div class="space-y-2">
                        <a href="/product/<%= product.slug %>" class="product-card_link">
                            <%= product.title %>
                        </a>
                        
                        <% if (product.brand) { %>
                        <p class="text-xs text-gray-400"><%= product.brand.title %></p>
                        <% } %>

                        <div class="product-card_price-wrapper">
                            <div class="product-card_rate">
                                <span class="text-gray-400 flex items-center text-sm gap-x-0.5">
                                    <p>5.0</p>
                                    <svg class="size-4 mb-1">
                                        <use href="#star"></use>
                                    </svg>
                                </span>
                            </div>
                            <div class="product-card_price">
                                <% if (product.priceSingle && product.originalPrice > product.priceSingle) { %>
                                <del><%= product.priceSingle.toLocaleString() %> <h6>تومان</h6></del>
                                <% } %>
                                <p><%= product.priceSingle.toLocaleString() %></p>
                                <span>تومان</span>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <!-- وقتی محصولی نیست -->
            <div class="flex flex-col items-center justify-center py-20">
                <svg class="size-10 text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <p class="text-gray-500 dark:text-gray-400 text-lg mb-2">محصولی یافت نشد!</p>
                <p class="text-gray-400 dark:text-gray-500 text-sm mb-4">فیلترهای خود را تغییر دهید</p>
                <button onclick="clearFilters()" class="px-6 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition">
                    حذف فیلترها
                </button>
            </div>
            <% } %>

            <!-- صفحه‌بندی -->
            <% if (products.totalPages > 1) { %>
            <div class="mt-10 w-full flex items-center justify-center">
                <ul class="flex items-center gap-x-2 child:flex child:items-center child:justify-center child:w-10 child:h-10 child:cursor-pointer child:shadow child:rounded-lg child:transition-all child:duration-300">
                    
                    <!-- دکمه قبلی -->
                    <% if (products.hasPrevPage) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700" onclick="goToPage(<%= products.prevPage %>)">
                        <svg class="size-5 rotate-180">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } else { %>
                    <li class="bg-gray-100 dark:bg-gray-700 cursor-not-allowed opacity-50">
                        <svg class="size-5 rotate-180">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } %>

                    <!-- صفحات -->
                    <% 
                    const currentPage = products.page;
                    const totalPages = products.totalPages;
                    let startPage = Math.max(1, currentPage - 2);
                    let endPage = Math.min(totalPages, currentPage + 2);
                    
                    if (currentPage <= 3) {
                        endPage = Math.min(5, totalPages);
                    }
                    if (currentPage >= totalPages - 2) {
                        startPage = Math.max(1, totalPages - 4);
                    }
                    %>

                    <!-- صفحه اول -->
                    <% if (startPage > 1) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white" onclick="goToPage(1)">
                        <a href="#">1</a>
                    </li>
                    <% if (startPage > 2) { %>
                    <li class="bg-white dark:bg-gray-800 cursor-default">...</li>
                    <% } %>
                    <% } %>

                    <!-- صفحات وسط -->
                    <% for (let i = startPage; i <= endPage; i++) { %>
                    <li class="<%= i === currentPage ? 'text-white bg-blue-500' : 'bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white' %>" 
                        onclick="goToPage(<%= i %>)">
                        <a href="#"><%= i %></a>
                    </li>
                    <% } %>

                    <!-- صفحه آخر -->
                    <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                    <li class="bg-white dark:bg-gray-800 cursor-default">...</li>
                    <% } %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white" onclick="goToPage(<%= totalPages %>)">
                        <a href="#"><%= totalPages %></a>
                    </li>
                    <% } %>

                    <!-- دکمه بعدی -->
                    <% if (products.hasNextPage) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700" onclick="goToPage(<%= products.nextPage %>)">
                        <svg class="size-5">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } else { %>
                    <li class="bg-gray-100 dark:bg-gray-700 cursor-not-allowed opacity-50">
                        <svg class="size-5">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } %>

                </ul>
            </div>

            <!-- اطلاعات صفحه‌بندی -->
            <div class="text-center mt-4 text-sm text-gray-500 dark:text-gray-400">
                نمایش <%= (products.page - 1) * products.limit + 1 %> - <%= Math.min(products.page * products.limit, products.totalDocs) %> از <%= products.totalDocs %> محصول
            </div>
            <% } %>

        </div>
    </div>
</main>

<!-- مودال مرتب‌سازی موبایل -->
<div class="sort-modal fixed inset-0 bg-black/50 z-50 hidden items-end justify-center" id="sortModal">
    <div class="bg-white dark:bg-gray-800 w-full rounded-t-2xl p-4 max-h-[70vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-4">
            <p class="font-DanaMedium text-gray-800 dark:text-gray-100">مرتب سازی</p>
            <button onclick="closeSortModal()">
                <svg class="size-5 text-gray-800 dark:text-gray-300">
                    <use href="#x-mark"></use>
                </svg>
            </button>
        </div>
        <ul class="flex flex-col divide-y divide-gray-200 dark:divide-gray-700">
            <li onclick="setSort('newest')" class="py-3 <%= currentFilters.sort === 'newest' ? 'text-blue-500' : 'text-gray-600 dark:text-gray-300' %>">جدیدترین</li>
            <li onclick="setSort('popular')" class="py-3 <%= currentFilters.sort === 'popular' ? 'text-blue-500' : 'text-gray-600 dark:text-gray-300' %>">محبوب‌ترین</li>
            <li onclick="setSort('bestselling')" class="py-3 <%= currentFilters.sort === 'bestselling' ? 'text-blue-500' : 'text-gray-600 dark:text-gray-300' %>">پرفروش‌ترین</li>
            <li onclick="setSort('cheapest')" class="py-3 <%= currentFilters.sort === 'cheapest' ? 'text-blue-500' : 'text-gray-600 dark:text-gray-300' %>">ارزان‌ترین</li>
            <li onclick="setSort('expensive')" class="py-3 <%= currentFilters.sort === 'expensive' ? 'text-blue-500' : 'text-gray-600 dark:text-gray-300' %>">گران‌ترین</li>
        </ul>
    </div>
</div>

<!-- مودال فیلتر موبایل -->
<div class="filter-modal fixed inset-0 bg-black/50 z-50 hidden items-end justify-center" id="filterModal">
    <div class="bg-white dark:bg-gray-800 w-full rounded-t-2xl p-4 max-h-[80vh] overflow-y-auto">
        <div class="flex justify-between items-center mb-4">
            <p class="font-DanaMedium text-gray-800 dark:text-gray-100">فیلترها</p>
            <button onclick="closeFilterModal()">
                <svg class="size-5 text-gray-800 dark:text-gray-300">
                    <use href="#x-mark"></use>
                </svg>
            </button>
        </div>
        <!-- محتوای فیلتر مثل سایدبار -->
        <!-- ... -->
        <button onclick="applyFilter(); closeFilterModal();" class="w-full mt-4 py-3 bg-blue-500 text-white rounded-lg">
            اعمال فیلترها
        </button>
    </div>
</div>

<script>
// اعمال فیلتر
function applyFilter() {
    const params = new URLSearchParams(window.location.search);
    
    // جستجو
    const search = document.getElementById('search-input')?.value;
    if (search) {
        params.set('search', search);
    } else {
        params.delete('search');
    }
    
    // دسته‌بندی
    const category = document.querySelector('input[name="category"]:checked');
    if (category) {
        params.set('category', category.value);
    } else {
        params.delete('category');
    }
    
    // برند
    const brand = document.querySelector('input[name="brand"]:checked');
    if (brand) {
        params.set('brand', brand.value);
    } else {
        params.delete('brand');
    }
    
    // محدوده قیمت
    const minPrice = document.getElementById('minPrice')?.value;
    const maxPrice = document.getElementById('maxPrice')?.value;
    if (minPrice) {
        params.set('minPrice', minPrice);
    } else {
        params.delete('minPrice');
    }
    if (maxPrice) {
        params.set('maxPrice', maxPrice);
    } else {
        params.delete('maxPrice');
    }
    
    // موجودی
    const inStock = document.getElementById('inStock-switch');
    if (inStock?.checked) {
        params.set('inStock', 'true');
    } else {
        params.delete('inStock');
    }
    
    // برگشت به صفحه 1
    params.delete('page');
    
    window.location.href = `/shop?${params.toString()}`;
}

// مرتب‌سازی
function setSort(sortValue) {
    const params = new URLSearchParams(window.location.search);
    params.set('sort', sortValue);
    params.delete('page');
    window.location.href = `/shop?${params.toString()}`;
}

// رفتن به صفحه
function goToPage(page) {
    const params = new URLSearchParams(window.location.search);
    params.set('page', page);
    window.location.href = `/shop?${params.toString()}`;
}

// حذف فیلتر خاص
function removeFilter(filterName) {
    const params = new URLSearchParams(window.location.search);
    
    if (filterName === 'price') {
        params.delete('minPrice');
        params.delete('maxPrice');
    } else {
        params.delete(filterName);
    }
    
    params.delete('page');
    window.location.href = `/shop?${params.toString()}`;
}

// حذف همه فیلترها
function clearFilters() {
    window.location.href = '/shop';
}

// آکاردئون
function toggleAccordion(index) {
    const content = document.getElementById(`content-${index}`);
    const icon = document.getElementById(`icon-${index}`);
    
    if (content.style.maxHeight && content.style.maxHeight !== '0px') {
        content.style.maxHeight = '0px';
        icon?.classList.remove('-rotate-90');
    } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        icon?.classList.add('-rotate-90');
    }
}

// مودال مرتب‌سازی
document.querySelector('.sort-modal-open')?.addEventListener('click', () => {
    document.getElementById('sortModal').classList.remove('hidden');
    document.getElementById('sortModal').classList.add('flex');
});

function closeSortModal() {
    document.getElementById('sortModal').classList.add('hidden');
    document.getElementById('sortModal').classList.remove('flex');
}

// مودال فیلتر
document.querySelector('.filter-modal-open')?.addEventListener('click', () => {
    document.getElementById('filterModal').classList.remove('hidden');
    document.getElementById('filterModal').classList.add('flex');
});

function closeFilterModal() {
    document.getElementById('filterModal').classList.add('hidden');
    document.getElementById('filterModal').classList.remove('flex');
}

// باز کردن آکاردئون‌ها اگه فیلتر فعال داریم
document.addEventListener('DOMContentLoaded', () => {
    <% if (currentFilters.category) { %>
    toggleAccordion(1);
    <% } %>
    <% if (currentFilters.brand) { %>
    toggleAccordion(2);
    <% } %>
    <% if (currentFilters.minPrice || currentFilters.maxPrice) { %>
    toggleAccordion(3);
    <% } %>
});
</script>

