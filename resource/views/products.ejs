<div class="container" style="padding: 2rem 0;">
    <!-- Page Header -->
    <div style="text-align: center; margin-bottom: 3rem;">
        <h1 style="color: var(--primary-blue);">محصولات</h1>
        <p style="color: #666;">بهترین مکمل‌های غذایی ورزشی</p>
    </div>
    
    <!-- Filters and Sorting -->
    <div style="display: grid; grid-template-columns: 250px 1fr; gap: 2rem;">
        
        <!-- Sidebar Filters -->
        <aside>
            <div class="card" style="padding: 1.5rem;">
                <h3 style="margin-bottom: 1.5rem; color: var(--dark-gray);">فیلترها</h3>
                
                <!-- Category Filter -->
                <div style="margin-bottom: 2rem;">
                    <h4 style="font-size: 1rem; margin-bottom: 1rem;">دسته‌بندی</h4>
                    <% 
                    const categories = ['پروتئین', 'کراتین', 'آمینو اسید', 'ویتامین', 'چربی سوز', 'گینر', 'پری ورکات', 'پست ورکات', 'سایر'];
                    %>
                    <% categories.forEach(cat => { %>
                        <label style="display: block; margin-bottom: 0.5rem; cursor: pointer;">
                            <input type="checkbox" name="category" value="<%= cat %>" onchange="filterProducts()" style="margin-left: 8px;">
                            <%= cat %>
                        </label>
                    <% }); %>
                </div>
                
                <!-- Price Range Filter -->
                <div style="margin-bottom: 2rem;">
                    <h4 style="font-size: 1rem; margin-bottom: 1rem;">محدوده قیمت</h4>
                    <input type="range" id="priceRange" min="0" max="5000000" step="100000" onchange="updatePriceLabel()" style="width: 100%;">
                    <div style="display: flex; justify-content: space-between; margin-top: 0.5rem;">
                        <span>0</span>
                        <span id="priceLabel">5,000,000</span>
                    </div>
                </div>
                
                <!-- Brand Filter -->
                <div style="margin-bottom: 2rem;">
                    <h4 style="font-size: 1rem; margin-bottom: 1rem;">برند</h4>
                    <% 
                    const brands = ['Optimum Nutrition', 'MuscleTech', 'BSN', 'Universal', 'Dymatize'];
                    %>
                    <% brands.forEach(brand => { %>
                        <label style="display: block; margin-bottom: 0.5rem; cursor: pointer;">
                            <input type="checkbox" name="brand" value="<%= brand %>" onchange="filterProducts()" style="margin-left: 8px;">
                            <%= brand %>
                        </label>
                    <% }); %>
                </div>
                
                <!-- Stock Filter -->
                <div style="margin-bottom: 1rem;">
                    <label style="display: block; cursor: pointer;">
                        <input type="checkbox" id="inStock" onchange="filterProducts()" style="margin-left: 8px;">
                        فقط کالاهای موجود
                    </label>
                </div>
                
                <button class="btn btn-secondary" style="width: 100%;" onclick="resetFilters()">
                    <i class="fas fa-undo"></i>
                    پاک کردن فیلترها
                </button>
            </div>
        </aside>
        
        <!-- Main Content -->
        <div>
            <!-- Sorting Bar -->
            <div class="card" style="padding: 1rem; margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <span style="color: #666;">تعداد محصولات: </span>
                    <strong><%= typeof products !== 'undefined' ? products.length : 0 %></strong>
                </div>
                
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <label>مرتب‌سازی:</label>
                    <select class="form-control" style="width: 200px;" onchange="sortProducts(this.value)">
                        <option value="newest">جدیدترین</option>
                        <option value="price-asc">قیمت - کم به زیاد</option>
                        <option value="price-desc">قیمت - زیاد به کم</option>
                        <option value="bestseller">پرفروش‌ترین</option>
                        <option value="rating">بیشترین امتیاز</option>
                    </select>
                </div>
            </div>
            
            <!-- Products Grid -->
            <div class="products-grid">
                <% if (typeof products !== 'undefined' && products.length > 0) { %>
                    <% products.forEach(product => { %>
                        <div class="card product-card" data-category="<%= product.category %>" data-brand="<%= product.brand %>" data-price="<%= product.currentPrice %>" data-stock="<%= product.stock %>">
                            <% if (product.discountPercentage > 0) { %>
                                <div style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                                    <span class="discount-badge">%<%= product.discountPercentage %> تخفیف</span>
                                </div>
                            <% } %>
                            
                            <% if (product.bestseller) { %>
                                <div style="position: absolute; top: 10px; left: 10px; z-index: 10;">
                                    <span style="background: var(--success); color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.875rem;">
                                        پرفروش
                                    </span>
                                </div>
                            <% } %>
                            
                            <img src="<%= product.images[0] || 'https://via.placeholder.com/300' %>" alt="<%= product.name %>" class="card-img">
                            
                            <div class="card-body">
                                <h3 class="card-title" style="font-size: 1.1rem;"><%= product.name %></h3>
                                <p style="color: var(--accent-orange); font-weight: 600; font-size: 0.9rem;"><%= product.brand %></p>
                                
                                <!-- Rating -->
                                <div style="margin: 0.5rem 0;">
                                    <% for(let i = 1; i <= 5; i++) { %>
                                        <i class="fas fa-star" style="color: <%= i <= product.ratings.average ? '#FFD700' : '#E0E0E0' %>; font-size: 0.9rem;"></i>
                                    <% } %>
                                    <span style="color: #666; font-size: 0.85rem; margin-right: 5px;">(<%= product.ratings.count %>)</span>
                                </div>
                                
                                <p class="card-text" style="font-size: 0.9rem;"><%= product.description.substring(0, 80) %>...</p>
                                
                                <!-- Stock Status -->
                                <% if (product.stock > 0) { %>
                                    <p style="color: var(--success); font-size: 0.85rem; margin: 0.5rem 0;">
                                        <i class="fas fa-check-circle"></i>
                                        موجود در انبار
                                    </p>
                                <% } else { %>
                                    <p style="color: var(--danger); font-size: 0.85rem; margin: 0.5rem 0;">
                                        <i class="fas fa-times-circle"></i>
                                        ناموجود
                                    </p>
                                <% } %>
                                
                                <div class="card-price">
                                    <span class="price-current"><%= product.currentPrice.toLocaleString('fa-IR') %> تومان</span>
                                    <% if (product.discountPrice) { %>
                                        <span class="price-original"><%= product.price.toLocaleString('fa-IR') %></span>
                                    <% } %>
                                </div>
                                
                                <div style="display: flex; gap: 10px; margin-top: 1rem;">
                                    <a href="/products/<%= product._id %>" class="btn btn-primary" style="flex: 1; font-size: 0.9rem; padding: 0.6rem;">
                                        <i class="fas fa-eye"></i>
                                        جزئیات
                                    </a>
                                    <% if (product.stock > 0) { %>
                                        <button onclick="addToCart('<%= product._id %>')" class="btn btn-accent" style="flex: 1; font-size: 0.9rem; padding: 0.6rem;">
                                            <i class="fas fa-cart-plus"></i>
                                            افزودن
                                        </button>
                                    <% } else { %>
                                        <button class="btn" disabled style="flex: 1; font-size: 0.9rem; padding: 0.6rem; background: #ccc; cursor: not-allowed;">
                                            ناموجود
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="text-align: center; grid-column: 1/-1; padding: 3rem; color: #666;">
                        <i class="fas fa-box-open" style="font-size: 3rem; display: block; margin-bottom: 1rem; color: #ccc;"></i>
                        محصولی یافت نشد
                    </p>
                <% } %>
            </div>
            
            <!-- Pagination -->
            <div style="display: flex; justify-content: center; margin-top: 3rem; gap: 0.5rem;">
                <button class="btn btn-secondary" style="padding: 0.5rem 1rem;">
                    <i class="fas fa-chevron-right"></i>
                </button>
                <button class="btn btn-primary" style="padding: 0.5rem 1rem;">1</button>
                <button class="btn btn-secondary" style="padding: 0.5rem 1rem;">2</button>
                <button class="btn btn-secondary" style="padding: 0.5rem 1rem;">3</button>
                <button class="btn btn-secondary" style="padding: 0.5rem 1rem;">
                    <i class="fas fa-chevron-left"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function filterProducts() {
    // Get all checked categories
    const checkedCategories = Array.from(document.querySelectorAll('input[name="category"]:checked')).map(cb => cb.value);
    const checkedBrands = Array.from(document.querySelectorAll('input[name="brand"]:checked')).map(cb => cb.value);
    const inStockOnly = document.getElementById('inStock').checked;
    const maxPrice = document.getElementById('priceRange').value;
    
    // Get all product cards
    const products = document.querySelectorAll('.product-card');
    
    products.forEach(product => {
        const category = product.dataset.category;
        const brand = product.dataset.brand;
        const price = parseInt(product.dataset.price);
        const stock = parseInt(product.dataset.stock);
        
        let show = true;
        
        // Category filter
        if (checkedCategories.length > 0 && !checkedCategories.includes(category)) {
            show = false;
        }
        
        // Brand filter
        if (checkedBrands.length > 0 && !checkedBrands.includes(brand)) {
            show = false;
        }
        
        // Price filter
        if (price > maxPrice) {
            show = false;
        }
        
        // Stock filter
        if (inStockOnly && stock === 0) {
            show = false;
        }
        
        product.style.display = show ? 'block' : 'none';
    });
}

function updatePriceLabel() {
    const value = document.getElementById('priceRange').value;
    document.getElementById('priceLabel').textContent = parseInt(value).toLocaleString('fa-IR');
    filterProducts();
}

function resetFilters() {
    // Uncheck all checkboxes
    document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
    
    // Reset price range
    document.getElementById('priceRange').value = 5000000;
    updatePriceLabel();
    
    // Show all products
    document.querySelectorAll('.product-card').forEach(product => {
        product.style.display = 'block';
    });
}

function sortProducts(sortBy) {
    // This would typically make an AJAX request to sort server-side
    window.location.href = `/products?sort=${sortBy}`;
}

function addToCart(productId) {
    fetch('/cart/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({ productId: productId })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Update cart count
            const cartCount = document.querySelector('.cart-count');
            if (cartCount) {
                cartCount.textContent = data.cartCount;
            } else {
                const cartBtn = document.querySelector('.fa-shopping-cart').parentElement;
                const span = document.createElement('span');
                span.className = 'cart-count';
                span.textContent = data.cartCount;
                cartBtn.appendChild(span);
            }
            
            showNotification('محصول به سبد خرید اضافه شد', 'success');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('خطا در افزودن به سبد خرید', 'error');
    });
}

function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} fade-in`;
    notification.style.position = 'fixed';
    notification.style.top = '80px';
    notification.style.left = '50%';
    notification.style.transform = 'translateX(-50%)';
    notification.style.zIndex = '9999';
    notification.innerHTML = `<i class="fas fa-${type === 'success' ? 'check' : 'times'}-circle"></i> ${message}`;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.style.opacity = '0';
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}
</script>
