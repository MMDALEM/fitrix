<main class="container relative">
    <div class="flex flex-col lg:flex-row gap-x-8 mt-10">
        <!-- SIDE MENU -->
        <%- include(viewPath('layout/menu')) %>
        <div
            class="flex flex-col shadow rounded-lg p-4 dark:bg-gray-800 bg-white mt-5 lg:mt-0 w-full">
            <div class="flex items-center justify-between">
                <h2 class="font-DanaMedium text-lg">ایجاد محصول جدید</h2>
            </div>

            <div class="flex items-center gap-x-4 mt-3">
                <a href="/admin/products"
                    class="flex items-center gap-x-1 text-blue-500">
                    <svg class="size-5">
                        <use href="#document"></use>
                    </svg>
                    <span class="font-DanaMedium">مشاهده همه محصولات</span>
                </a>
            </div>

            <div class="flex items-center gap-x-4 mt-3">
                <a href="/admin/product/page"
                    class="flex items-center gap-x-1 text-red-500">
                    <svg class="size-5">
                        <use href="#document"></use>
                    </svg>
                    <span class="font-DanaMedium"> دانلود pdf </span>
                </a>
            </div>
        <div class="lg:w-3/4">

            <!-- محصولات -->
            <% if (products.docs.length > 0) { %>
            <div class="grid grid-cols-1 xxs:grid-cols-2 xs:grid-cols-2 sm:grid-cols-2 xl:grid-cols-3 gap-3 xs:gap-2 sm:gap-4">
                <% products.docs.forEach((product) => { %>
                <div class="product-card group">
                    <div class="product-card_header">
                        <div class="flex items-center gap-x-2">
                            <div class="tooltip">
                                <button class="rounded-full p-1.5 app-border app-hover">
                                    <svg class="size-4">
                                        <use href="#shopping-cart"></use>
                                    </svg>
                                </button>
                                <div class="tooltiptext">سبد خرید</div>
                            </div>
                            <div class="tooltip">
                                <button class="rounded-full p-1.5 app-border app-hover">
                                    <svg class="size-4">
                                        <use href="#heart"></use>
                                    </svg>
                                </button>
                                <div class="tooltiptext">علاقه‌مندی</div>
                            </div>
                        </div>
                        <% if (product.originalPrice && product.originalPrice > product.priceSingle) { %>
                        <span class="product-card_badge">
                            <%= Math.round((1 - product.priceSingle / product.originalPrice) * 100) %>% تخفیف
                        </span>
                        <% } %>
                    </div>

                    <a href="/admin/product/edit/<%= product._id %>" class="object-contain object-center h-full w-32 mx-auto transition-transform duration-300 group-hover:scale-105">
                        <img style="object-fit: scale-down;" class="product-card_img" 
                            src="<%= product.image %>"
                            alt="<%= product.title %>">
                    </a>



                    <div class="space-y-2">
                        <a href="/admin/product/edit/<%= product.id %>" class="product-card_link">
                            <%= product.title %>
                        </a>
                        
                        <% if (product.brand) { %>
                        <p class="text-xs text-gray-400"><%= product.brand.title %></p>
                        <% } %>

                        <div class="product-card_price-wrapper">
                            <div class="product-card_rate">
                                <span class="text-gray-400 flex items-center text-sm gap-x-0.5">
                                    <p>5.0</p>
                                    <svg class="size-4 mb-1">
                                        <use href="#star"></use>
                                    </svg>
                                </span>
                            </div>
                            <div class="product-card_price">
                                <% if (product.priceSingle && product.originalPrice > product.priceSingle) { %>
                                <del><%= product.priceSingle.toLocaleString() %> <h6>تومان</h6></del>
                                <% } %>
                                <p><%= product.priceSingle.toLocaleString() %></p>
                                <span>تومان</span>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <!-- وقتی محصولی نیست -->
            <div class="flex flex-col items-center justify-center py-20">
                <svg class="size-10 text-gray-300 dark:text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <p class="text-gray-500 dark:text-gray-400 text-lg mb-2">محصولی یافت نشد!</p>
                <p class="text-gray-400 dark:text-gray-500 text-sm mb-4">فیلترهای خود را تغییر دهید</p>
            </div>
            <% } %>

            <!-- صفحه‌بندی -->
            <% if (products.totalPages > 1) { %>
            <div class="mt-10 w-full flex items-center justify-center">
                <ul class="flex items-center gap-x-2 child:flex child:items-center child:justify-center child:w-10 child:h-10 child:cursor-pointer child:shadow child:rounded-lg child:transition-all child:duration-300">
                    
                    <!-- دکمه قبلی -->
                    <% if (products.hasPrevPage) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700" onclick="goToPage(<%= products.prevPage %>)">
                        <svg class="size-5 rotate-180">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } else { %>
                    <li class="bg-gray-100 dark:bg-gray-700 cursor-not-allowed opacity-50">
                        <svg class="size-5 rotate-180">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } %>

                    <!-- صفحات -->
                    <% 
                    const currentPage = products.page;
                    const totalPages = products.totalPages;
                    let startPage = Math.max(1, currentPage - 2);
                    let endPage = Math.min(totalPages, currentPage + 2);
                    
                    if (currentPage <= 3) {
                        endPage = Math.min(5, totalPages);
                    }
                    if (currentPage >= totalPages - 2) {
                        startPage = Math.max(1, totalPages - 4);
                    }
                    %>

                    <!-- صفحه اول -->
                    <% if (startPage > 1) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white" onclick="goToPage(1)">
                        <a href="#">1</a>
                    </li>
                    <% if (startPage > 2) { %>
                    <li class="bg-white dark:bg-gray-800 cursor-default">...</li>
                    <% } %>
                    <% } %>

                    <!-- صفحات وسط -->
                    <% for (let i = startPage; i <= endPage; i++) { %>
                    <li class="<%= i === currentPage ? 'text-white bg-blue-500' : 'bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white' %>" 
                        onclick="goToPage(<%= i %>)">
                        <a href="#"><%= i %></a>
                    </li>
                    <% } %>

                    <!-- صفحه آخر -->
                    <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                    <li class="bg-white dark:bg-gray-800 cursor-default">...</li>
                    <% } %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-blue-500 hover:text-white" onclick="goToPage(<%= totalPages %>)">
                        <a href="#"><%= totalPages %></a>
                    </li>
                    <% } %>

                    <!-- دکمه بعدی -->
                    <% if (products.hasNextPage) { %>
                    <li class="bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700" onclick="goToPage(<%= products.nextPage %>)">
                        <svg class="size-5">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } else { %>
                    <li class="bg-gray-100 dark:bg-gray-700 cursor-not-allowed opacity-50">
                        <svg class="size-5">
                            <use href="#chevron-left"></use>
                        </svg>
                    </li>
                    <% } %>

                </ul>
            </div>

            <!-- اطلاعات صفحه‌بندی -->
            <div class="text-center mt-4 text-sm text-gray-500 dark:text-gray-400">
                نمایش <%= (products.page - 1) * products.limit + 1 %> - <%= Math.min(products.page * products.limit, products.totalDocs) %> از <%= products.totalDocs %> محصول
            </div>
            <% } %>

        </div>
        </div>
    </div>
</main>

<script>
    const uploadArea = document.getElementById('uploadArea')
    const imageInput = document.getElementById('imageInput')
    const placeholder = document.getElementById('uploadPlaceholder')
    const preview = document.getElementById('uploadPreview')
    const previewImg = document.getElementById('previewImg')
    const previewName = document.getElementById('previewName')
    const imageError = document.getElementById('imageError')

    // drag & drop
    uploadArea.addEventListener('dragover', e => {
        e.preventDefault()
        uploadArea.classList.add('border-blue-400', 'bg-blue-50',
            'dark:bg-blue-900/10')
    })

    uploadArea.addEventListener('dragleave', () => {
        uploadArea.classList.remove('border-blue-400', 'bg-blue-50',
            'dark:bg-blue-900/10')
    })

    uploadArea.addEventListener('drop', e => {
        e.preventDefault()
        uploadArea.classList.remove('border-blue-400', 'bg-blue-50',
            'dark:bg-blue-900/10')
        const file = e.dataTransfer.files[0]
        if (file) processFile(file)
    })

    function handleImageSelect(e) {
        const file = e.target.files[0]
        if (file) processFile(file)
    }

    function processFile(file) {
        imageError.classList.add('hidden')

        // چک سایز
        if (file.size > 5 * 1024 * 1024) {
            showError('حجم فایل نباید بیشتر از ۵ مگابایت باشد')
            return
        }

        // چک نوع فایل
        const allowed = ['image/jpeg', 'image/png', 'image/webp']
        if (!allowed.includes(file.type)) {
            showError('فقط فایل‌های JPG، PNG و WEBP مجاز هستند')
            return
        }

        // نمایش پیش‌نمایش
        const reader = new FileReader()
        reader.onload = e => {
            previewImg.src = e.target.result
            previewName.textContent =
                `${file.name} (${(file.size / 1024).toFixed(1)} KB)`
            placeholder.classList.add('hidden')
            preview.classList.remove('hidden')
        }
        reader.readAsDataURL(file)

        // انتقال فایل به input اصلی
        const dt = new DataTransfer()
        dt.items.add(file)
        imageInput.files = dt.files
    }

    function removeImg(e) {
        e.stopPropagation()
        imageInput.value = ''
        previewImg.src = ''
        preview.classList.add('hidden')
        placeholder.classList.remove('hidden')
    }

    function showError(msg) {
        imageError.textContent = msg
        imageError.classList.remove('hidden')
        imageInput.value = ''
    }

    // جلوگیری از submit اگه عکس انتخاب نشده
    document.querySelector('form').addEventListener('submit', e => {
        if (!imageInput.files || !imageInput.files[0]) {
            e.preventDefault()
            showError('انتخاب تصویر محصول الزامی است')
            document.getElementById('uploadArea').scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            })
        }
    })
</script>