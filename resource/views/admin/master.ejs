<!doctype html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>پنل مدیریت | <%= settings.siteName %></title>
    <link rel="stylesheet" href="/styles/app.css">
    <link rel="stylesheet" href="/styles/swiper-bundle.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.3/dist/sweetalert2.min.css" >
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <!-- شبکه‌ی ایمنی تصاویر پنل ادمین -->
    <style>
        img { max-width: 100%; }
        .product-card > a { display: block; width: 100% !important; height: 12rem !important; position: relative; }
        .product-card_img { width: 100% !important; height: 12rem !important; object-fit: contain !important; }
        @media (max-width: 480px) {
            .product-card > a { height: 9.5rem !important; }
            .product-card_img { height: 9.5rem !important; }
        }
    </style>
    <!-- ==========================  DARK MODE SCRIPT ============================= -->
    <script type="text/javascript">
        if (
            localStorage.theme === "dark" ||
            (!("theme" in localStorage) &&
                window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
            document.documentElement.classList.add("dark");
        } else {
            document.documentElement.classList.remove("dark");
        }
    </script>
</head>

<body>

    <%- include(viewPath('layout/header')) %><%- include(viewPath('layout/svg')) %> <%- body %> <%- include(viewPath('layout/footer')) %>
    <%- include(viewPath('layout/consult-widget')) %>
    <div class="overlay"></div>
    <div class="search-overlay"></div>
    
    <script src="/scripts/img-blur.js"></script>
    <script src="/scripts/swiper-bundle.min.js"></script>
    <script src="/scripts/app.js"></script>
    <script src="/scripts/slider.js" type="module"></script>
    <script src="/scripts/timer.js"></script>
    <script src="/scripts/sweetalert2.all.min.js"></script>
    
    <script src="/js/conf.js"></script>
    <script src="/js/jquery-3.2.1.slim.min.js"></script>
    <script src="/js/1.12.9.popper.min.js"></script>
    <!-- منوی کاربریِ موبایلِ پنل ادمین روی همه‌ی صفحات ادمین کار کند -->
    <script src="/scripts/dashboard.js"></script>
    <%- include(viewPath('layout/sweetalert')) %>
</body>

</html>