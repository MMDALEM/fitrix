<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>کاتالوگ محصولات | فیت ریکس</title>
  <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Vazirmatn', Tahoma, Arial, sans-serif;
      background: #294669;
      min-height: 100vh;
      color: #0f172a;
      padding: 16px;
      direction: rtl;
    }

    .container { max-width: 1280px; margin: 0 auto; }

    .header {
      background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
      color: white;
      padding: 18px 24px;
      border-radius: 14px;
      box-shadow: 0 6px 24px rgba(2, 132, 199, 0.2);
      margin-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .brand-block { display: flex; align-items: center; gap: 12px; }
    .brand-logo {
      width: 44px; height: 44px;
      background: white; color: #0284c7;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 18px;
    }
    .brand-text h1 { font-size: 20px; font-weight: 800; }
    .brand-text p { font-size: 12px; opacity: 0.92; margin-top: 2px; }
    .meta-info { text-align: left; font-size: 11px; opacity: 0.95; line-height: 1.6; }
    .meta-info strong { font-weight: 600; }

    .toolbar {
      background: white;
      padding: 16px 24px;
      border-radius: 14px;
      margin-bottom: 24px;
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      box-shadow: 0 2px 12px rgba(2, 132, 199, 0.08);
    }

    .search-input {
      flex: 1; min-width: 220px;
      padding: 10px 16px;
      border: 2px solid #e0f2fe;
      border-radius: 10px;
      font-family: inherit; font-size: 14px;
      outline: none; transition: border-color 0.2s;
    }
    .search-input:focus { border-color: #0ea5e9; }

    .filter-select {
      padding: 10px 14px;
      border: 2px solid #e0f2fe;
      border-radius: 10px;
      font-family: inherit; font-size: 14px;
      background: white; cursor: pointer; outline: none;
      min-width: 160px;
    }

    /* ===== انتخاب درصد (لینک‌های EJS) ===== */
    .price-tier {
      display: inline-flex;
      gap: 4px;
      background: #e0f2fe;
      padding: 4px;
      border-radius: 10px;
    }
    .price-tier a {
      text-decoration: none;
      padding: 7px 14px;
      border-radius: 7px;
      font-size: 13px;
      font-weight: 700;
      color: #0284c7;
      transition: background 0.15s, color 0.15s;
    }
    .price-tier a.active {
      background: #0284c7;
      color: white;
    }

    /* ===== درصد دلخواه ===== */
    .custom-percent {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: #e0f2fe;
      padding: 4px 6px;
      border-radius: 10px;
    }
    .percent-input {
      width: 110px;
      padding: 7px 10px;
      border: 2px solid #bae6fd;
      border-radius: 7px;
      font-family: inherit; font-size: 13px; font-weight: 700;
      color: #0284c7; background: white;
      outline: none; text-align: center;
    }
    .percent-input:focus { border-color: #0ea5e9; }
    .percent-suffix { font-size: 13px; font-weight: 700; color: #0284c7; }

    .btn {
      padding: 10px 20px;
      border: none; border-radius: 10px;
      font-family: inherit; font-size: 14px; font-weight: 600;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
      display: inline-flex; align-items: center; gap: 6px;
      text-decoration: none;
    }
    .btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(0,0,0,0.12); }
    .btn-primary { background: #0284c7; color: white; }
    .btn-secondary { background: #e0f2fe; color: #0284c7; }

    .summary {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      margin-bottom: 18px;
    }
    .summary-card {
      background: white;
      padding: 12px 16px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(2, 132, 199, 0.06);
      border-right: 3px solid #0ea5e9;
    }
    .summary-card .label { font-size: 11px; color: #64748b; margin-bottom: 4px; }
    .summary-card .value { font-size: 20px; font-weight: 700; color: #0284c7; }

    .category-section {
      background-color: #e0f2fe;
      border-radius: 14px;
      padding: 16px 18px;
      margin-bottom: 16px;
      box-shadow: 0 2px 12px rgba(2, 132, 199, 0.06);
      page-break-inside: auto;
    }
    .category-header {
      display: flex; align-items: center; gap: 10px;
      padding-bottom: 10px; margin-bottom: 14px;
      border-bottom: 2px dashed #e0f2fe;
    }
    .category-icon {
      width: 34px; height: 34px;
      background: linear-gradient(135deg, #0ea5e9, #0284c7);
      color: white; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; font-weight: 700; flex-shrink: 0;
    }
    .category-title { font-size: 16px; font-weight: 700; color: #0c4a6e; }
    .category-count {
      background: #e0f2fe; color: #0284c7;
      padding: 3px 10px; border-radius: 16px;
      font-size: 11px; font-weight: 600; margin-right: auto;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 10px;
    }
    .product-card {
      border: 1px solid #e0f2fe;
      border-radius: 10px;
      overflow: hidden;
      background: #fafdff;
      transition: transform 0.2s, box-shadow 0.2s;
      display: flex; flex-direction: column;
      page-break-inside: avoid;
    }
    .product-card:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(2, 132, 199, 0.12); }

    .product-image-wrap {
      width: 100%; aspect-ratio: 1;
      background: #f0f9ff; overflow: hidden; position: relative;
    }
    .product-image-wrap img { width: 100%; height: 100%; object-fit: scale-down; }
    .product-image-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: #94a3b8; font-size: 11px;
    }

    .sale-badge {
      position: absolute; top: 6px; right: 6px;
      background: #ef4444; color: white;
      padding: 2px 7px; border-radius: 6px;
      font-size: 9px; font-weight: 700;
    }
    .featured-badge {
      position: absolute; top: 6px; left: 6px;
      background: #f59e0b; color: white;
      padding: 2px 7px; border-radius: 6px;
      font-size: 9px; font-weight: 700;
    }

    .product-body { padding: 8px 10px 10px; flex: 1; display: flex; flex-direction: column; }
    .product-brand {
      font-size: 9px; color: #0284c7; font-weight: 600;
      background: #e0f2fe; padding: 2px 7px; border-radius: 12px;
      align-self: flex-start; margin-bottom: 5px;
    }
    .product-title {
      font-size: 12px; font-weight: 700; color: #0f172a;
      margin-bottom: 6px; line-height: 1.4;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
      overflow: hidden; min-height: 32px;
    }
    .product-meta {
      display: flex; flex-wrap: wrap; gap: 3px;
      margin-bottom: 6px; font-size: 9px; color: #64748b;
    }
    .product-meta span { background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }

    .product-footer {
      margin-top: auto; padding-top: 6px;
      border-top: 1px dashed #e2e8f0;
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 4px;
    }
    .product-price { font-size: 13px; font-weight: 800; color: #0284c7; }
    .product-price .currency { font-size: 9px; color: #64748b; font-weight: 500; margin-right: 2px; }
    /* حالت «بدون قیمت»: قیمت‌ها و ابزارهای مربوط به قیمت پنهان شوند (در چاپ هم اعمال می‌شود) */
    body.no-prices .product-price,
    body.no-prices .custom-percent,
    body.no-prices .price-tier { display: none !important; }

    .product-stock { font-size: 9px; padding: 2px 6px; border-radius: 5px; font-weight: 600; }
    .stock-in { background: #dcfce7; color: #16a34a; }
    .stock-out { background: #fee2e2; color: #dc2626; }

    .empty-state {
      text-align: center; padding: 80px 20px;
      background: white; border-radius: 16px; color: #64748b;
    }

    @media print {
      body { background: white; padding: 0; margin: 0; }
      .toolbar { display: none !important; }
      .header {
        background: #0284c7 !important;
        -webkit-print-color-adjust: exact; print-color-adjust: exact;
        box-shadow: none; margin-bottom: 10px; padding: 12px 18px; border-radius: 8px;
      }
      .summary { margin-bottom: 10px; gap: 6px; }
      .summary-card { box-shadow: none; border: 1px solid #e0f2fe; padding: 8px 10px; }
      .summary-card .value { font-size: 16px; }
      .summary-card .label { font-size: 10px; }
      .category-section {
        box-shadow: none; border: 1px solid #e0f2fe;
        page-break-inside: auto; padding: 12px; margin-bottom: 10px;
      }
      .category-header { padding-bottom: 8px; margin-bottom: 10px; }
      .product-grid { grid-template-columns: repeat(4, 1fr) !important; gap: 8px; }
      .product-card { page-break-inside: avoid; box-shadow: none; border-radius: 8px; }
      .product-card:hover { transform: none; box-shadow: none; }
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    }

    @page { size: A4; margin: 8mm; }
  </style>
</head>
<body>
  <div class="container">

    <%
      // درصد انتخاب‌شده از query string (پیش‌فرض: 10)
      var tier = (typeof query !== 'undefined' && query.tier) ? String(query.tier) : '10';
      var validTiers = ['single', '5', '10', '15', '20'];
      if (validTiers.indexOf(tier) === -1) tier = '10';

      // درصد دلخواه از query string (۱ تا ۱۰۰)؛ اگر معتبر نبود نادیده گرفته می‌شود
      var customPercent = null;
      if (typeof query !== 'undefined' && query.percent != null && query.percent !== '') {
        var cp = Number(query.percent);
        if (!isNaN(cp)) {
          cp = Math.max(1, Math.min(100, Math.round(cp)));
          customPercent = cp;
        }
      }

      // پایه‌ی قیمت به تومان = قیمت خام درهم × نرخ لحظه‌ی درهم
      function priceBase(p){
        return (Number(p.originalPrice) || 0) * (Number(p.AED) || 0);
      }

      // اعمال درصد روی پایه + گرد کردن به بالا به نزدیک‌ترین ۱۰۰۰۰ (همان منطق سرور)
      function priceWithPercent(base, percent){
        return Math.ceil((base * (1 + percent / 100)) / 10000) * 10000;
      }

      // قیمت هر محصول بر اساس درصد انتخاب‌شده
      function priceByTier(p){
        // اگر درصد دلخواه وارد شده باشد، اولویت با آن است
        if (customPercent != null) {
          return priceWithPercent(priceBase(p), customPercent);
        }
        switch (tier) {
          case 'single': return p.priceSingle || 0;
          case '5':      return p.priceHigh5 || 0;
          case '15':     return p.priceHigh15 || 0;
          case '20':     return p.priceHigh20 || 0;
          default:       return p.priceHigh10 || 0;
        }
      }
    %>

    <!-- ===== Header ===== -->
    <div class="header">
      <!-- =====<div class="brand-block">
        <div class="brand-logo">FR</div>
        <div class="brand-text">
          <h1>فیت ریکس</h1>
          <p>کاتالوگ کامل محصولات</p>
        </div>
      </div>
      <div class="meta-info">
        <div><strong>تاریخ تولید:</strong> <span id="gen-date"></span></div>
        <div><strong>تعداد دسته‌بندی:</strong> <%= categories.length %></div>
        <div><strong>تعداد برند:</strong> <%= brands.length %></div>
      </div>-->
    </div>

    <!-- ===== Toolbar ===== -->
    <div class="toolbar">
      <input type="text" class="search-input" id="searchInput" placeholder="🔍 جستجو در نام محصول..." />
      <select class="filter-select" id="brandFilter">
        <option value="">همه برندها</option>
        <% brands.forEach(function(b){ %>
          <option value="<%= b._id %>"><%= b.title %></option>
        <% }) %>
      </select>

      <!-- درصد دلخواه — هر عددی از ۱ تا ۱۰۰ -->
      <div class="custom-percent">
        <input type="number" id="percentInput" class="percent-input" min="1" max="100" step="1"
               placeholder="درصد دلخواه" value="<%= customPercent != null ? customPercent : '' %>" />
        <span class="percent-suffix">٪</span>
        <button type="button" class="btn btn-primary" onclick="applyCustomPercent()">اعمال</button>
      </div>

      <!-- عدم نمایش قیمت‌ها (لیست بدون قیمت) -->
      <label class="hide-prices-toggle" style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;user-select:none;">
        <input type="checkbox" id="hidePrices" onchange="togglePrices()" style="width:16px;height:16px;cursor:pointer;">
        بدون قیمت
      </label>

      <button class="btn btn-secondary" onclick="resetFilters()">پاک کردن فیلتر</button>
      <button class="btn btn-primary" onclick="window.print()">📄 ذخیره به PDF / چاپ</button>
    </div>

    <!-- ===== Summary ===== -->
    <div class="summary">
      <div class="summary-card">
        <div class="label">مجموع محصولات</div>
        <div class="value"><%= products.length %></div>
      </div>
      <div class="summary-card">
        <div class="label">دسته‌بندی‌ها</div>
        <div class="value"><%= categories.length %></div>
      </div>
      <div class="summary-card">
        <div class="label">برندها</div>
        <div class="value"><%= brands.length %></div>
      </div>
      <div class="summary-card">
        <div class="label">تاریخ کاتالوگ</div>
        <div class="value" ><%= catalogDate %></div>
      </div>
    </div>

    <%
      function getCategoryProducts(catId){
        return products.filter(function(p){
          if(!p.category) return false;
          var pid = p.category._id ? p.category._id.toString() : p.category.toString();
          return pid === catId.toString();
        });
      }
      function getBrandById(brandId){
        if(!brandId) return null;
        var bid = brandId._id ? brandId._id.toString() : brandId.toString();
        return brands.find(function(b){ return b._id.toString() === bid; });
      }
      var hasAnyProduct = false;
    %>

    <% categories.forEach(function(cat){ %>
      <% var catProducts = getCategoryProducts(cat._id); %>
      <% if(catProducts.length > 0){ hasAnyProduct = true; %>
        <div class="category-section" data-category="<%= cat._id %>">
          <div class="category-header">
            <div class="category-icon">
              <% if(cat.icon){ %><%= cat.icon %><% } else { %><%= cat.title.charAt(0) %><% } %>
            </div>
            <div>
              <div class="category-title"><%= cat.title %></div>
              <% if(cat.description){ %>
                <div style="font-size:13px;color:#64748b;margin-top:4px;"><%= cat.description %></div>
              <% } %>
            </div>
            <span class="category-count"><%= catProducts.length %> محصول</span>
          </div>

          <div class="product-grid">
            <% catProducts.forEach(function(p){ %>
              <% var brand = getBrandById(p.brand); %>
              <div class="product-card"
                   data-title="<%= p.title.toLowerCase() %>"
                   data-brand="<%= brand ? brand._id : '' %>">
                <div class="product-image-wrap">
                  <% if(p.image){ %>
                    <img src="<%= p.image %>" alt="<%= p.title %>" onerror="this.onerror=null;this.parentElement.innerHTML='<div class=\'product-image-placeholder\'>بدون تصویر</div>'" />
                  <% } else { %>
                    <div class="product-image-placeholder">بدون تصویر</div>
                  <% } %>
                  <% if(p.onSale){ %><div class="sale-badge">تخفیف</div><% } %>
                  <% if(p.featured){ %><div class="featured-badge">⭐ ویژه</div><% } %>
                </div>
                <div class="product-body">
                  <% if(brand){ %>
                    <div class="product-brand"><%= brand.title %></div>
                  <% } %>
                  <div class="product-title"><%= p.title %></div>

                  <div class="product-meta">
                    <% if(p.weight){ %><span>وزن: <%= p.weight %></span><% } %>
                    <% if(p.servings){ %><span>سروینگ: <%= p.servings %></span><% } %>
                    <% if(p.flavor){ %><span>طعم: <%= p.flavor %></span><% } %>
                  </div>

                  <div class="product-footer">
                    <div class="product-price">
                      <span class="price-value"
                            data-base="<%= Math.round(priceBase(p)) %>"
                            data-single="<%= (p.darsad && p.darsad.single != null) ? p.darsad.single : 0 %>"><%= Number(priceByTier(p)).toLocaleString('fa-IR') %></span>
                      <span class="currency">تومان</span>
                    </div>
                    <% if(p.quantity > 0){ %>
                      <span class="product-stock stock-in">موجود </span>
                    <% } else { %>
                      <span class="product-stock stock-out">ناموجود</span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    <% }) %>

    <%
      var orphanProducts = products.filter(function(p){
        if(!p.category) return true;
        var pid = p.category._id ? p.category._id.toString() : p.category.toString();
        return !categories.find(function(c){ return c._id.toString() === pid; });
      });
    %>
    <% if(orphanProducts.length > 0){ hasAnyProduct = true; %>
      <div class="category-section">
        <div class="category-header">
          <div class="category-icon">?</div>
          <div>
            <div class="category-title">سایر محصولات</div>
            <div style="font-size:13px;color:#64748b;margin-top:4px;">محصولات بدون دسته‌بندی</div>
          </div>
          <span class="category-count"><%= orphanProducts.length %> محصول</span>
        </div>
        <div class="product-grid">
          <% orphanProducts.forEach(function(p){ %>
            <% var brand = getBrandById(p.brand); %>
            <div class="product-card"
                 data-title="<%= p.title.toLowerCase() %>"
                 data-brand="<%= brand ? brand._id : '' %>">
              <div class="product-image-wrap">
                <% if(p.image){ %>
                  <img src="<%= p.image %>" alt="<%= p.title %>" />
                <% } else { %>
                  <div class="product-image-placeholder">بدون تصویر</div>
                <% } %>
              </div>
              <div class="product-body">
                <% if(brand){ %><div class="product-brand"><%= brand.title %></div><% } %>
                <div class="product-title"><%= p.title %></div>
                <div class="product-footer">
                  <div class="product-price">
                    <span class="price-value"
                          data-base="<%= Math.round(priceBase(p)) %>"
                          data-single="<%= (p.darsad && p.darsad.single != null) ? p.darsad.single : 0 %>"><%= Number(priceByTier(p)).toLocaleString('fa-IR') %></span>
                    <span class="currency">تومان</span>
                  </div>
                  <% if(p.quantity > 0){ %>
                    <span class="product-stock stock-in">موجود</span>
                  <% } else { %>
                    <span class="product-stock stock-out">ناموجود</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if(!hasAnyProduct){ %>
      <div class="empty-state">
        <h2 style="color:#0284c7;margin-bottom:8px;">هیچ محصولی یافت نشد</h2>
        <p>هنوز محصولی به سیستم اضافه نشده است.</p>
      </div>
    <% } %>

  </div>

  <script>
    var genDate = document.getElementById('gen-date');
    if (genDate) genDate.textContent = new Date().toLocaleDateString('fa-IR');

    var searchInput = document.getElementById('searchInput');
    var brandFilter = document.getElementById('brandFilter');
    var percentInput = document.getElementById('percentInput');

    // نمایش/عدم‌نمایش قیمت‌ها — برای گرفتن لیست بدون قیمت
    function togglePrices(){
      var cb = document.getElementById('hidePrices');
      document.body.classList.toggle('no-prices', cb && cb.checked);
    }

    // اعمال درصد روی پایه + گرد کردن به بالا به نزدیک‌ترین ۱۰۰۰۰ (همان منطق سرور)
    function calcPrice(base, percent){
      return Math.ceil((base * (1 + percent / 100)) / 10000) * 10000;
    }

    // درصد را روی همه‌ی قیمت‌ها اعمال و زنده بازمحاسبه می‌کند
    function recalcPrices(percent){
      document.querySelectorAll('.price-value').forEach(function(el){
        var base = Number(el.dataset.base) || 0;
        var pct = percent;
        // اگر درصد دلخواه خالی بود، از درصد تکی همان محصول استفاده می‌شود
        if (pct == null) pct = Number(el.dataset.single) || 0;
        el.textContent = calcPrice(base, pct).toLocaleString('fa-IR');
      });
    }

    // خواندن و محدودسازی درصد ورودی به بازه‌ی ۱ تا ۱۰۰
    function readPercent(){
      var raw = percentInput ? percentInput.value.trim() : '';
      if (raw === '') return null;
      var v = Number(raw);
      if (isNaN(v)) return null;
      v = Math.max(1, Math.min(100, Math.round(v)));
      return v;
    }

    // اعمال درصد دلخواه و به‌روزرسانی آدرس برای حفظ مقدار هنگام چاپ/تازه‌سازی
    function applyCustomPercent(){
      var v = readPercent();
      if (v == null) return;
      percentInput.value = v;
      recalcPrices(v);
      var url = new URL(window.location.href);
      url.searchParams.set('percent', v);
      window.history.replaceState({}, '', url);
    }

    if (percentInput) {
      // بازمحاسبه‌ی زنده هنگام تایپ
      percentInput.addEventListener('input', function(){
        var v = readPercent();
        recalcPrices(v);
      });
      percentInput.addEventListener('keydown', function(e){
        if (e.key === 'Enter') { e.preventDefault(); applyCustomPercent(); }
      });
    }

    function applyFilters(){
      var q = searchInput.value.trim().toLowerCase();
      var brand = brandFilter.value;
      var cards = document.querySelectorAll('.product-card');

      cards.forEach(function(card){
        var matchTitle = !q || card.dataset.title.indexOf(q) !== -1;
        var matchBrand = !brand || card.dataset.brand === brand;
        card.style.display = (matchTitle && matchBrand) ? '' : 'none';
      });

      document.querySelectorAll('.category-section').forEach(function(sec){
        var visible = sec.querySelectorAll('.product-card:not([style*="display: none"])').length;
        sec.style.display = visible > 0 ? '' : 'none';
      });
    }

    function resetFilters(){
      searchInput.value = '';
      brandFilter.value = '';
      applyFilters();
    }

    searchInput.addEventListener('input', applyFilters);
    brandFilter.addEventListener('change', applyFilters);
  </script>
</body>
</html>
