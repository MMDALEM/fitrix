From 73dc8a0505fd248f034313dedc219f95b1c03141 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Thu, 9 Jul 2026 09:38:55 +0000
Subject: [PATCH] seo: add Latin brand (FitRix/fitrix.ir) to title, description
 and JSON-LD
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- برند لاتین به تایتل و توضیحات پیش‌فرض اضافه شد تا سرچ «fitrix» هم برند را پیدا کند
- alternateName در structured data برای شناخت برند توسط گوگل

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_013THoEh9wHdFuKfkpQ4AyhW
---
 resource/views/home/master.ejs          | 7 +++++--
 src/controllers/home/home.controller.js | 2 +-
 src/middlewares/globalData.js           | 2 +-
 3 files changed, 7 insertions(+), 4 deletions(-)

diff --git a/resource/views/home/master.ejs b/resource/views/home/master.ejs
index 35afad4..7cb6205 100644
--- a/resource/views/home/master.ejs
+++ b/resource/views/home/master.ejs
@@ -7,9 +7,10 @@
     <%
         // مقادیر SEO با fallback امن — کنترلرها می‌توانند بازنویسی کنند
         var _siteName = settings.siteName || "فیت ریکس شاپ";
+        var _siteNameEn = settings.siteNameEn || "FitRix";
         var _title = (typeof pageTitle !== "undefined" && pageTitle)
-            ? pageTitle + " | " + _siteName
-            : _siteName + " | خرید مکمل و لوازم ورزشی";
+            ? pageTitle + " | " + _siteName + " (" + _siteNameEn + ")"
+            : _siteName + " (" + _siteNameEn + ") | خرید مکمل ورزشی | fitrix.ir";
         var _desc = (typeof metaDescription !== "undefined" && metaDescription) ? metaDescription : "";
         var _canonical = (typeof canonicalUrl !== "undefined" && canonicalUrl) ? canonicalUrl : "";
         var _ogImage = (typeof ogImage !== "undefined" && ogImage) ? ogImage : "/images/logo.png";
@@ -52,6 +53,7 @@
       "@context": "https://schema.org",
       "@type": "Organization",
       "name": "<%= _siteName %>",
+      "alternateName": ["<%= _siteNameEn %>", "Fitrix", "فیت ریکس"],
       "url": "<%= _siteUrl %>/",
       "logo": "<%= _siteUrl %>/images/logo.png",
       "contactPoint": {
@@ -66,6 +68,7 @@
       "@context": "https://schema.org",
       "@type": "WebSite",
       "name": "<%= _siteName %>",
+      "alternateName": ["<%= _siteNameEn %>", "Fitrix", "فیت ریکس"],
       "url": "<%= _siteUrl %>/",
       "potentialAction": {
         "@type": "SearchAction",
diff --git a/src/controllers/home/home.controller.js b/src/controllers/home/home.controller.js
index 5668981..b4e334f 100644
--- a/src/controllers/home/home.controller.js
+++ b/src/controllers/home/home.controller.js
@@ -33,7 +33,7 @@ class homeController extends controller {
         slides,
         products,
         metaDescription:
-          "فیت ریکس شاپ؛ فروشگاه اینترنتی مکمل ورزشی. خرید پروتئین وی، کراتین، گینر، آمینو و ویتامین از برندهای معتبر جهانی با قیمت مناسب و ارسال سریع به سراسر ایران.",
+          "فروشگاه اینترنتی فیت ریکس (FitRix | fitrix.ir)؛ خرید مکمل ورزشی، پروتئین وی، کراتین، گینر، آمینو و ویتامین از برندهای معتبر جهانی با قیمت مناسب و ارسال سریع به سراسر ایران.",
       });
     } catch (err) {
       next(err);
diff --git a/src/middlewares/globalData.js b/src/middlewares/globalData.js
index a2f830a..7f424e4 100644
--- a/src/middlewares/globalData.js
+++ b/src/middlewares/globalData.js
@@ -76,7 +76,7 @@ class GlobalData {
     res.locals.canonicalUrl = siteUrl + req.path;
     res.locals.pageTitle = null;
     res.locals.metaDescription =
-      "فروشگاه اینترنتی فیت ریکس شاپ؛ خرید انواع مکمل ورزشی، پروتئین وی، کراتین، گینر و ویتامین از برندهای معتبر جهانی با قیمت مناسب و ارسال سریع.";
+      "فروشگاه اینترنتی فیت ریکس (FitRix | fitrix.ir)؛ خرید انواع مکمل ورزشی، پروتئین وی، کراتین، گینر و ویتامین از برندهای معتبر جهانی با قیمت مناسب و ارسال سریع.";
     res.locals.ogImage = siteUrl + "/images/logo.png";
     res.locals.ogType = "website";
     res.locals.noindex = false;
-- 
2.43.0

