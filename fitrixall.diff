+
+    // درصد را روی همه‌ی قیمت‌ها اعمال و زنده بازمحاسبه می‌کند
+    function recalcPrices(percent){
+      document.querySelectorAll('.price-value').forEach(function(el){
+        var base = Number(el.dataset.base) || 0;
+        var pct = percent;
+        // اگر درصد دلخواه خالی بود، از درصد تکی همان محصول استفاده می‌شود
+        if (pct == null) pct = Number(el.dataset.single) || 0;
+        el.textContent = calcPrice(base, pct).toLocaleString('fa-IR');
+      });
+    }
+
+    // خواندن و محدودسازی درصد ورودی به بازه‌ی ۱ تا ۱۰۰
+    function readPercent(){
+      var raw = percentInput ? percentInput.value.trim() : '';
+      if (raw === '') return null;
+      var v = Number(raw);
+      if (isNaN(v)) return null;
+      v = Math.max(1, Math.min(100, Math.round(v)));
+      return v;
+    }
+
+    // اعمال درصد دلخواه و به‌روزرسانی آدرس برای حفظ مقدار هنگام چاپ/تازه‌سازی
+    function applyCustomPercent(){
+      var v = readPercent();
+      if (v == null) return;
+      percentInput.value = v;
+      recalcPrices(v);
+      var url = new URL(window.location.href);
+      url.searchParams.set('percent', v);
+      window.history.replaceState({}, '', url);
+    }
+
+    if (percentInput) {
+      // بازمحاسبه‌ی زنده هنگام تایپ
+      percentInput.addEventListener('input', function(){
+        var v = readPercent();
+        recalcPrices(v);
+      });
+      percentInput.addEventListener('keydown', function(e){
+        if (e.key === 'Enter') { e.preventDefault(); applyCustomPercent(); }
+      });
+    }
 
